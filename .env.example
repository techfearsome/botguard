# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/botguard

# Redis (for rate limiting, hot session cache - optional in week 1)
REDIS_URL=redis://localhost:6379

# Session signing key (REQUIRED - must be at least 16 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# Admin login (REQUIRED to access /admin)
ADMIN_USERNAME=admin
# Either set the plaintext password here (gets hashed in memory at startup):
ADMIN_PASSWORD=changeme
# OR pre-hash it and set ADMIN_PASSWORD_HASH instead (preferred for production):
# Generate with: npm run hash-password
# ADMIN_PASSWORD_HASH=

# Default workspace (single-tenant for now, multi-tenant ready)
DEFAULT_WORKSPACE_SLUG=techfirio

# ProxyCheck.io (week 2 - leave blank for now)
PROXYCHECK_API_KEY=

# Trust proxy configuration. Use 'cloudflare' when behind Cloudflare (recommended).
# Other values: a number (1 = trust 1 hop), 'true' (trust all - INSECURE in prod).
# - 'cloudflare' restricts trust to Cloudflare's documented IP ranges + loopback (for nginx in front of us)
# - This prevents header spoofing where a malicious upstream could fake X-Forwarded-For
TRUST_PROXY=cloudflare
