# ═══════════════════════════════════════════════════════════════════════
#  BotGuard — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in the values.
#  Only MONGO_URI, SESSION_SECRET, and ADMIN_PASSWORD are required.
#  Everything else has sensible defaults.
# ═══════════════════════════════════════════════════════════════════════


# ── Core (required) ───────────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/botguard

# Secret for Express session cookies (random string, 32+ chars)
SESSION_SECRET=change-me-to-something-random

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional: pre-hashed password (bcrypt). If set, ADMIN_PASSWORD is ignored.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('yourpass', 10))"
# ADMIN_PASSWORD_HASH=

# Public-facing URL of your BotGuard instance (used in sitemaps, headers, WP fingerprint)
# Critical behind reverse proxies (Cloudflare → Coolify → Docker) where
# req.protocol returns http instead of https.
BASE_URL=https://yourdomain.com


# ── Server ────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=production

# Trust proxy headers (set to 1 behind Cloudflare/Coolify/Docker)
TRUST_PROXY=1

# Redis URL for rate limiting and pattern filter (optional — falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Workspace slug for single-tenant deployments
DEFAULT_WORKSPACE_SLUG=default


# ── ProxyCheck.io (Layer 1 proxy detection) ───────────────────────────

# API key from proxycheck.io — required for proxy/VPN detection
PROXYCHECK_API_KEY=your-proxycheck-api-key


# ── Residential Proxy Detection (Layer 2) ─────────────────────────────
# Set ONE OR MORE of these keys. Per-campaign provider selection in the UI.
# 'auto' mode picks the first configured provider.

# ipgeolocation.io — 2 credits per lookup
# Sign up: https://ipgeolocation.io
# IPGEO_API_KEY=

# Spur — Context API
# Sign up: https://app.spur.us
# SPUR_API_TOKEN=

# ipinfo.io — Privacy + Residential Proxy detection
# Sign up: https://ipinfo.io
# IPINFO_TOKEN=


# ── Cloudflare Edge Firewall ──────────────────────────────────────────
# Blocks bot traffic at Cloudflare's edge before it reaches your server.
# API token needs: Workers Scripts:Edit + Workers KV Storage:Edit + Zone Workers Routes:Edit

# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# CF_KV_NAMESPACE_ID=

# Shared secret for Worker → BotGuard log authentication
# Generate with: openssl rand -hex 32
# CF_SYNC_KEY=


# ── Google Ads IP Exclusion Sync ──────────────────────────────────────
# Syncs intelligence CIDRs to Google Ads campaign IP exclusions via a
# Google Ads Script. Feature is OFF by default — enable in Intelligence → Settings.

# Shared secret for Google Ads Script → BotGuard API authentication
# GADS_SYNC_KEY=

# These can also be set via UI at /admin/intelligence/settings:
# GADS_EXCLUSION_LIMIT=500     # Google's per-campaign limit
# GADS_MIN_SCORE=50            # Minimum intelligence score to export
# GADS_RESERVE_SLOTS=50        # Slots reserved for manual entries


# ── UA Parser ─────────────────────────────────────────────────────────
# ua-parser-js version is auto-detected. Set this to enable Pro extensions.

# Set to 'true' if you have a ua-parser-js Pro/Business license
# Enables: Crawlers, InApps, Fetchers, CLIs extensions + isBot/isAICrawler helpers
# UAPARSER_PRO=false


# ── CIDR Intelligence Analyser ────────────────────────────────────────

# How often the analyser runs (default: every 60 seconds)
# CIDR_ANALYSIS_INTERVAL_SECONDS=60

# Rolling window for click analysis (default: 24 hours)
# CIDR_ANALYSIS_WINDOW_HOURS=24

# Weekly deep refresh schedule (rebuilds historical aggregates)
# CIDR_WEEKLY_REFRESH_DAY=0      # 0=Sunday
# CIDR_WEEKLY_REFRESH_HOUR=3     # 3 AM
# CIDR_WEEKLY_REFRESH_MINUTE=0
# CIDR_WEEKLY_REFRESH_WINDOW_HOURS=168  # 7 days

# Intelligence maintenance interval (auto-archive + auto-escalate)
# INTEL_MAINTENANCE_INTERVAL_MINUTES=60


# ── Misc ──────────────────────────────────────────────────────────────

# Set to '1' to add noindex to all pages (staging/dev environments)
# BG_NO_INDEX=0

# Static asset cache buster (auto-generated if not set)
# BUILD_ID=
