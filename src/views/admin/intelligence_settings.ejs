<%- include('../partials/header', { ws, page, title: 'Intelligence Settings - BotGuard' }) %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
  <div>
    <h1 style="margin-bottom:4px;">Intelligence Settings</h1>
    <p class="muted">Configure automatic export of flagged CIDRs to the Cloudflare edge firewall.</p>
  </div>
  <a href="/admin/intelligence" class="btn">← Back to Intelligence</a>
</div>

<% if (flash) { %>
<div style="background:var(--color-background-info,#E6F1FB); border:1px solid var(--color-border-info,#85B7EB); border-radius:var(--radius-md); padding:10px 14px; margin-bottom:16px; font-size:13px; color:var(--color-text-info,#185FA5);">
  <%= flash %>
</div>
<% } %>

<%# ── Auto-export to Cloudflare ──────────────────────────────────── %>
<section class="panel" style="margin-bottom:24px;">
  <h3>Auto-Export to Cloudflare</h3>
  <p class="muted" style="margin-bottom:16px;">
    When enabled, CIDRs that meet the threshold criteria below will be automatically
    added to the Cloudflare edge firewall rules. This runs after each intelligence
    analysis cycle (every 60 seconds).
  </p>

  <form method="POST" action="/admin/intelligence/settings" class="form" style="max-width:none;">

    <div class="form-row">
      <label style="display:flex; align-items:center; gap:10px;">
        <input type="checkbox" name="enabled" <%= autoCf.enabled ? 'checked' : '' %> style="width:auto;">
        <span>Enable auto-export to Cloudflare</span>
      </label>
    </div>

    <div class="grid-2" style="margin-top:12px;">
      <div>
        <div class="form-row">
          <label>Minimum score</label>
          <select name="min_score">
            <option value="80" <%= autoCf.min_score >= 80 ? 'selected' : '' %>>Critical only (80+)</option>
            <option value="60" <%= autoCf.min_score === 60 ? 'selected' : '' %>>High+ (60+)</option>
            <option value="40" <%= autoCf.min_score === 40 ? 'selected' : '' %>>Medium+ (40+)</option>
            <option value="20" <%= autoCf.min_score === 20 ? 'selected' : '' %>>All scored (20+)</option>
          </select>
          <small class="muted">Only export CIDRs with a score at or above this threshold.</small>
        </div>

        <div class="form-row">
          <label>Minimum days seen</label>
          <select name="min_days">
            <option value="1" <%= autoCf.min_days === 1 ? 'selected' : '' %>>1 day (export immediately)</option>
            <option value="2" <%= autoCf.min_days === 2 ? 'selected' : '' %>>2 days</option>
            <option value="3" <%= autoCf.min_days === 3 ? 'selected' : '' %>>3 days</option>
            <option value="5" <%= autoCf.min_days === 5 ? 'selected' : '' %>>5 days</option>
            <option value="7" <%= autoCf.min_days === 7 ? 'selected' : '' %>>7 days</option>
          </select>
          <small class="muted">Block must be seen on at least this many days before auto-exporting.</small>
        </div>
      </div>

      <div>
        <div class="form-row">
          <label>Minimum hits</label>
          <select name="min_hits">
            <option value="3"  <%= autoCf.min_hits === 3  ? 'selected' : '' %>>3+ hits</option>
            <option value="5"  <%= autoCf.min_hits === 5  ? 'selected' : '' %>>5+ hits</option>
            <option value="10" <%= autoCf.min_hits === 10 ? 'selected' : '' %>>10+ hits</option>
            <option value="20" <%= autoCf.min_hits === 20 ? 'selected' : '' %>>20+ hits</option>
            <option value="50" <%= autoCf.min_hits === 50 ? 'selected' : '' %>>50+ hits</option>
          </select>
          <small class="muted">Minimum total click count before auto-exporting.</small>
        </div>

        <div class="form-row">
          <label style="display:flex; align-items:center; gap:10px;">
            <input type="checkbox" name="auto_sync" <%= autoCf.auto_sync !== false ? 'checked' : '' %> style="width:auto;">
            <span>Auto-sync to Cloudflare KV after adding</span>
          </label>
          <small class="muted">Push the updated blocklist to Cloudflare immediately after adding new rules.</small>
        </div>
      </div>
    </div>

    <div class="form-actions" style="margin-top:16px;">
      <button type="submit" class="btn btn-primary">Save settings</button>
    </div>
  </form>
</section>

<%# ── Current status ──────────────────────────────────────────────── %>
<section class="panel" style="margin-bottom:24px;">
  <h3>Status</h3>
  <div style="display:flex; gap:16px; flex-wrap:wrap; margin-bottom:16px;">
    <div class="stat-card" style="flex:1; min-width:120px;">
      <div class="stat-label">Auto-export</div>
      <div class="stat-value" style="color:<%= autoCf.enabled ? '#22c55e' : '#ef4444' %>;">
        <%= autoCf.enabled ? 'ON' : 'OFF' %>
      </div>
    </div>
    <div class="stat-card" style="flex:1; min-width:120px;">
      <div class="stat-label">Qualifying now</div>
      <div class="stat-value"><%= qualifyingCount %></div>
      <div class="stat-sub">CIDRs meeting thresholds</div>
    </div>
    <div class="stat-card" style="flex:1; min-width:120px;">
      <div class="stat-label">CF rules total</div>
      <div class="stat-value"><%= cfRuleCount %></div>
    </div>
    <div class="stat-card" style="flex:1; min-width:120px;">
      <div class="stat-label">Last auto-run</div>
      <div class="stat-value" style="font-size:14px;">
        <%= autoCf.last_run_at ? new Date(autoCf.last_run_at).toLocaleString() : 'Never' %>
      </div>
      <% if (autoCf.last_exported_count > 0) { %>
        <div class="stat-sub">Exported <%= autoCf.last_exported_count %> CIDRs</div>
      <% } %>
    </div>
  </div>

  <div style="display:flex; gap:8px;">
    <form method="POST" action="/admin/intelligence/settings/run-auto-export">
      <button type="submit" class="btn" <%= autoCf.enabled ? '' : 'disabled title="Enable auto-export first"' %>>
        Run auto-export now
      </button>
    </form>
    <a href="/admin/cloudflare" class="btn">View Cloudflare rules →</a>
  </div>
</section>

<%# ── Threshold preview ──────────────────────────────────────────── %>
<section class="panel">
  <h3>Current thresholds</h3>
  <p class="muted" style="margin-bottom:12px;">
    With the current settings, a CIDR block will be auto-exported to Cloudflare when it meets
    <strong>all</strong> of these conditions:
  </p>
  <div style="background:var(--bg-code, #1a1a2e); padding:14px 18px; border-radius:var(--radius-md); font-family:var(--font-mono); font-size:13px; line-height:1.8; color:var(--text-primary);">
    score >= <strong style="color:#f97316;"><%= autoCf.min_score %></strong><br>
    AND days_seen >= <strong style="color:#f97316;"><%= autoCf.min_days %></strong><br>
    AND hit_count >= <strong style="color:#f97316;"><%= autoCf.min_hits %></strong><br>
    AND cf_exported == <strong style="color:#22c55e;">false</strong> (not already in Cloudflare)<br>
    AND status IN <strong style="color:#3b82f6;">['new', 'reviewing', 'blocked', 'exported']</strong> (not dismissed)
  </div>
</section>

<%- include('../partials/footer') %>
