<%- include('../partials/header', { ws, page, title: 'Settings - BotGuard' }) %>

<div class="page-header">
  <h1>Settings</h1>
  <p class="muted">Logged in as <strong><%= adminUser %></strong></p>
</div>

<section class="panel">
  <h3>Admin Password</h3>
  <p>The admin password is set via the <code>ADMIN_PASSWORD</code> or <code>ADMIN_PASSWORD_HASH</code> environment variable. To change it:</p>
  <ol>
    <li>Generate a new hash: <code>npm run hash-password</code></li>
    <li>Set <code>ADMIN_PASSWORD_HASH</code> in your environment (or your hosting provider's config panel)</li>
    <li>Restart the server</li>
  </ol>
  <p class="muted">Storing the hash (rather than plaintext) is recommended for production.</p>
</section>

<section class="panel">
  <h3>API Keys</h3>
  <p>API keys can authenticate programmatic requests (postbacks, future API endpoints).
     Pass via <code>X-API-Key</code> header or <code>?api_key=</code> query string.</p>

  <% if (generated) { %>
    <div style="background:#fff3cd;color:#8a6d11;padding:12px;border-radius:4px;margin-bottom:12px;">
      <strong>New key generated — copy this now, you won't see it again:</strong>
      <pre style="background:#fff;padding:8px;margin-top:8px;border-radius:3px;word-break:break-all;"><%= generated %></pre>
    </div>
  <% } %>

  <form method="POST" action="/admin/settings/api-keys" class="form-inline" style="padding:0; margin-bottom:16px;">
    <input type="text" name="label" placeholder="Label (e.g. 'cron jobs')" required>
    <button type="submit" class="btn btn-primary">Generate new key</button>
  </form>

  <% if (!ws.api_keys || ws.api_keys.length === 0) { %>
    <p class="muted">No API keys yet.</p>
  <% } else { %>
    <table class="table table-dense">
      <tr><th>Label</th><th>Key (last 8)</th><th>Created</th><th>Last used</th><th></th></tr>
      <% ws.api_keys.forEach(k => { %>
        <tr>
          <td><%= k.label || '–' %></td>
          <td><code>…<%= k.key.slice(-8) %></code></td>
          <td><%= new Date(k.created_at).toLocaleString() %></td>
          <td><%= k.last_used_at ? new Date(k.last_used_at).toLocaleString() : 'never' %></td>
          <td>
            <form method="POST" action="/admin/settings/api-keys/<%= encodeURIComponent(k.key) %>/delete" style="display:inline" onsubmit="return confirm('Revoke this key?')">
              <button type="submit" class="btn btn-small btn-danger">Revoke</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </table>
  <% } %>
</section>

<section class="panel" id="tracking">
  <h3>Page Tracking</h3>
  <p class="muted">
    Inject third-party analytics into every offer and safe page rendered by <code>/go/&lt;slug&gt;</code>.
    Useful for session replay (Microsoft Clarity), heatmaps, and ad-platform pixels.
  </p>

  <%
    const trackingId = ws.settings?.tracking?.clarity_project_id || '';
  %>

  <form method="POST" action="/admin/settings/tracking" class="form" style="padding:0;">
    <div class="form-row">
      <label>Microsoft Clarity Project ID</label>
      <input type="text" name="clarity_project_id"
             value="<%= trackingId %>"
             pattern="[a-zA-Z0-9-]{1,32}"
             placeholder="e.g. wjsr5hjt53"
             maxlength="32">
      <small class="muted">
        Find this in your Clarity dashboard at <a href="https://clarity.microsoft.com/" target="_blank" rel="noopener">clarity.microsoft.com</a>
        under Settings → Setup. Leave blank to disable. Once set, the Clarity script is injected
        into every offer AND safe page so you can review session recordings of both successful
        and blocked traffic.
      </small>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save tracking settings</button>
    </div>
  </form>

  <% if (trackingId) { %>
    <div style="background:#e8f4ea;color:#1f6b3a;padding:10px 12px;border-radius:4px;margin-top:12px;">
      Clarity is currently <strong>active</strong> on all pages. Project ID: <code><%= trackingId %></code>
    </div>
  <% } %>
</section>

<section class="panel">
  <h3>Workspace Info</h3>
  <table class="table table-dense">
    <tr><td>Slug</td><td><code><%= ws.slug %></code></td></tr>
    <tr><td>Name</td><td><%= ws.name %></td></tr>
    <tr><td>Owner email</td><td><%= ws.owner_email || '–' %></td></tr>
    <tr><td>Default threshold</td><td><%= ws.settings?.default_threshold ?? 70 %></td></tr>
    <tr><td>Default mode</td><td><%= ws.settings?.default_mode || 'log_only' %></td></tr>
    <tr><td>Created</td><td><%= new Date(ws.created_at).toLocaleString() %></td></tr>
  </table>
</section>

<%- include('../partials/footer') %>
