<%- include('../partials/header', { ws, page, title: (campaign ? 'Edit' : 'New') + ' Campaign - BotGuard' }) %>

<div class="page-header">
  <h1><%= campaign ? 'Edit Campaign' : 'New Campaign' %></h1>
</div>

<form method="POST" action="<%= campaign ? '/admin/campaigns/' + campaign._id : '/admin/campaigns' %>" class="form">
  <div class="form-row">
    <label>Name</label>
    <input type="text" name="name" value="<%= campaign?.name || '' %>" required>
  </div>

  <div class="form-row">
    <label>Slug <span class="muted">(optional — auto-generated from name if empty)</span></label>
    <input type="text" name="slug" value="<%= campaign?.slug || '' %>" pattern="[a-z0-9-]*" placeholder="leave blank to auto-generate">
    <small class="muted">URL will be: <code>/go/&lt;slug&gt;</code>. If the generated slug already exists, a random suffix is appended.</small>
  </div>

  <div class="form-row">
    <label>Status</label>
    <select name="status">
      <% ['active', 'paused', 'archived'].forEach(s => { %>
        <option value="<%= s %>" <%= campaign?.status === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </div>

  <div class="form-row">
    <label>Source Profile</label>
    <select name="source_profile">
      <% ['mixed', 'email', 'paid_ads', 'organic', 'affiliate'].forEach(s => { %>
        <option value="<%= s %>" <%= campaign?.source_profile === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
    <small class="muted">Determines how filter scores are weighted. Pick the dominant traffic source for this campaign.</small>
  </div>

  <div class="form-row">
    <label>Landing Page (offer)</label>
    <select name="landing_page_id">
      <option value="">– None (renders stub) –</option>
      <% pages.filter(p => p.kind !== 'safe').forEach(p => { %>
        <option value="<%= p._id %>" <%= campaign?.landing_page_id?.toString() === p._id.toString() ? 'selected' : '' %>>
          <%= p.name %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-row">
    <label>Safe Page (shown to filtered traffic)</label>
    <select name="safe_page_id">
      <option value="">– None –</option>
      <% pages.filter(p => p.kind === 'safe').forEach(p => { %>
        <option value="<%= p._id %>" <%= campaign?.safe_page_id?.toString() === p._id.toString() ? 'selected' : '' %>>
          <%= p.name %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-row">
    <label>Filter Threshold (0–100)</label>
    <input type="number" name="threshold" min="0" max="100" value="<%= campaign?.filter_config?.threshold ?? 70 %>">
    <small class="muted">Block when total bot score reaches this value. Higher = more permissive.</small>
  </div>

  <div class="form-row">
    <label>Mode</label>
    <select name="mode">
      <option value="log_only" <%= campaign?.filter_config?.mode === 'log_only' ? 'selected' : '' %>>log_only — log decisions but always render offer</option>
      <option value="enforce" <%= campaign?.filter_config?.mode === 'enforce' ? 'selected' : '' %>>enforce — actually block bad traffic</option>
    </select>
  </div>

  <fieldset style="border:1px solid #e1e4ea; border-radius:6px; padding:14px 16px; margin-bottom:16px;">
    <legend style="font-weight:600; padding:0 6px;">UTM Gate</legend>
    <p class="muted" style="margin-top:0;">
      When enabled, visits missing required UTM keys are routed to the safe page. Useful to keep
      direct visits, scrapers, and stripped social shares off the offer page.
    </p>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="utm_gate_enabled"
          <%= campaign?.filter_config?.utm_gate?.enabled ? 'checked' : '' %>>
        Enable UTM gate
      </label>
    </div>

    <div class="form-row">
      <label>Required UTM keys</label>
      <%
        const requiredKeys = campaign?.filter_config?.utm_gate?.required_keys || ['source','medium','campaign'];
      %>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <% ['source', 'medium', 'campaign', 'term', 'content'].forEach(k => { %>
          <label style="font-weight:normal;">
            <input type="checkbox" name="utm_required_keys" value="<%= k %>"
              <%= requiredKeys.includes(k) ? 'checked' : '' %>>
            utm_<%= k %>
          </label>
        <% }) %>
      </div>
      <small class="muted">A visit must have ALL the checked keys present (and non-empty) to reach the offer.</small>
    </div>
  </fieldset>

  <fieldset style="border:1px solid #e1e4ea; border-radius:6px; padding:14px 16px; margin-bottom:16px;">
    <legend style="font-weight:600; padding:0 6px;">Country Gate</legend>
    <p class="muted" style="margin-top:0;">
      Cross-checks ProxyCheck's country verdict against your list. Whitelist mode = only listed
      countries pass. Blacklist mode = listed countries blocked.
      Requires <code>PROXYCHECK_API_KEY</code> to be set; otherwise <code>on_unknown</code> decides.
    </p>

    <%
      const cg = campaign?.filter_config?.country_gate || {};
      const cgList = Array.isArray(cg.countries) ? cg.countries.join(', ') : '';
    %>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="country_gate_enabled" <%= cg.enabled ? 'checked' : '' %>>
        Enable country gate
      </label>
    </div>

    <div class="grid-2">
      <div class="form-row">
        <label>Mode</label>
        <select name="country_gate_mode">
          <option value="whitelist" <%= cg.mode !== 'blacklist' ? 'selected' : '' %>>
            whitelist — only listed countries pass
          </option>
          <option value="blacklist" <%= cg.mode === 'blacklist' ? 'selected' : '' %>>
            blacklist — listed countries blocked
          </option>
        </select>
      </div>
      <div class="form-row">
        <label>If country unknown</label>
        <select name="country_gate_on_unknown">
          <option value="allow" <%= cg.on_unknown !== 'block' ? 'selected' : '' %>>
            allow (permissive — pass through)
          </option>
          <option value="block" <%= cg.on_unknown === 'block' ? 'selected' : '' %>>
            block (strict — show safe page)
          </option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <label>Country list (ISO 3166-1 alpha-2 codes, comma-separated)</label>
      <textarea name="country_list" rows="3" placeholder="US, CA, GB, AU, DE, FR"><%= cgList %></textarea>
      <small class="muted">
        Two-letter codes only. Common: US (United States), GB (United Kingdom), CA (Canada),
        AU (Australia), DE (Germany), FR (France), IN (India). Case insensitive; invalid entries are dropped.
      </small>
    </div>
  </fieldset>

  <fieldset style="border:1px solid #e1e4ea; border-radius:6px; padding:14px 16px; margin-bottom:16px;">
    <legend style="font-weight:600; padding:0 6px;">Proxy Gate</legend>
    <p class="muted" style="margin-top:0;">
      Hard route to safe page on proxy/VPN/Tor detection. Reads ProxyCheck verdict +
      ASN/term blacklist. Tighter than score-based filtering — when this fires the visit
      is blocked regardless of other layers.
    </p>

    <%
      const pg = campaign?.filter_config?.proxy_gate || {};
      // Defaults align with model defaults: VPN/Tor/public/compromised ON, hosting OFF
      const defaultBool = (v, def) => v === undefined ? def : !!v;
    %>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="proxy_gate_enabled" <%= pg.enabled ? 'checked' : '' %>>
        Enable proxy gate
      </label>
    </div>

    <div class="form-row">
      <label>Block on detection of:</label>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_vpn" <%= defaultBool(pg.block_vpn, true) ? 'checked' : '' %>>
          VPN
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_tor" <%= defaultBool(pg.block_tor, true) ? 'checked' : '' %>>
          Tor
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_public_proxy" <%= defaultBool(pg.block_public_proxy, true) ? 'checked' : '' %>>
          Public proxy
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_compromised" <%= defaultBool(pg.block_compromised, true) ? 'checked' : '' %>>
          Compromised
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_hosting" <%= defaultBool(pg.block_hosting, false) ? 'checked' : '' %>>
          Datacenter / hosting
        </label>
      </div>
      <small class="muted">
        "Datacenter" is off by default because corporate VPNs land in those ranges and you'll false-positive real users.
      </small>
    </div>

    <div class="form-row">
      <label>Max risk score (ProxyCheck's own 0–100 score)</label>
      <input type="number" name="proxy_max_risk_score" min="0" max="100" value="<%= pg.max_risk_score ?? 100 %>">
      <small class="muted">Block when ProxyCheck's risk score exceeds this. 100 = disabled.</small>
    </div>
  </fieldset>

  <div class="form-row">
    <label>S2S Postback URL <span class="muted">(optional)</span></label>
    <input type="text" name="postback_url" value="<%= campaign?.postback_url || '' %>" placeholder="https://your-tracker.example.com/postback?clickid={click_id}">
  </div>

  <div class="form-row">
    <label>Notes</label>
    <textarea name="notes" rows="3"><%= campaign?.notes || '' %></textarea>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= campaign ? 'Save changes' : 'Create campaign' %></button>
    <a href="/admin/campaigns" class="btn">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
