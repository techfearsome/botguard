<%- include('../partials/header', { ws, page, title: (campaign ? 'Edit' : 'New') + ' Campaign - BotGuard' }) %>

<div class="page-header">
  <h1><%= campaign ? 'Edit Campaign' : 'New Campaign' %></h1>
</div>

<form method="POST" action="<%= campaign ? '/admin/campaigns/' + campaign._id : '/admin/campaigns' %>" class="form">
  <div class="form-row">
    <label>Name</label>
    <input type="text" name="name" value="<%= campaign?.name || '' %>" required>
  </div>

  <div class="form-row">
    <label>Slug <span class="muted">(optional — auto-generated from name if empty)</span></label>
    <input type="text" name="slug" value="<%= campaign?.slug || '' %>" pattern="[a-z0-9-]*" placeholder="leave blank to auto-generate">
    <small class="muted">URL will be: <code>/go/&lt;slug&gt;</code>. If the generated slug already exists, a random suffix is appended.</small>
  </div>

  <div class="form-row">
    <label>Custom URL path <span class="muted">(optional)</span></label>
    <%
      const baseUrl = (locals.baseUrl || '').replace(/\/$/, '');
      const rootPath = campaign?.root_path || '';
    %>
    <div style="display:flex; align-items:center; gap:6px;">
      <span class="muted" style="font-family: var(--font-mono); font-size: 13px; white-space: nowrap;"><%= baseUrl || 'https://yourdomain.com' %>/</span>
      <input type="text" name="root_path" id="root_path_input" value="<%= rootPath %>"
             pattern="[a-z0-9][a-z0-9_-]{1,63}"
             maxlength="64"
             placeholder="e.g. promo, black-friday, special-offer">
    </div>
    <small class="muted">
      Lets the campaign be reached at a custom URL like <code><%= baseUrl || 'https://yourdomain.com' %>/promo</code> in addition to <code>/go/&lt;slug&gt;</code>. Leave blank if you only want the default <code>/go/</code> URL.
      <br>Reserved paths like <code>admin</code>, <code>privacy</code>, <code>p</code>, <code>api</code> are blocked. Lowercase letters, digits, hyphens, and underscores only. 2-64 characters.
    </small>
    <% if (rootPath) { %>
      <div style="margin-top: 8px; padding: 8px 12px; background: var(--success-bg); color: var(--success); border-radius: var(--radius-sm); font-size: 13px;">
        Active at: <code style="background:transparent; border:0; color:inherit; padding:0;"><%= baseUrl %>/<%= rootPath %></code>
      </div>
    <% } %>
  </div>

  <div class="form-row form-row-highlight">
    <label style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
      <strong>Campaign status</strong>
      <% if (campaign?.status === 'active') { %>
        <span class="badge badge-allow">Active</span>
      <% } else if (campaign?.status === 'paused') { %>
        <span class="badge badge-block">Paused</span>
      <% } else if (campaign?.status === 'archived') { %>
        <span class="badge badge-status-archived">Archived</span>
      <% } %>
    </label>
    <select name="status" style="max-width:280px;">
      <option value="active" <%= (!campaign || campaign.status === 'active') ? 'selected' : '' %>>Active — process traffic normally</option>
      <option value="paused" <%= campaign?.status === 'paused' ? 'selected' : '' %>>Paused — send all traffic to safe page</option>
      <option value="archived" <%= campaign?.status === 'archived' ? 'selected' : '' %>>Archived — return 404 (campaign hidden)</option>
    </select>
    <small class="muted" style="display:block; margin-top:8px;">
      <strong>Active</strong> runs the full pipeline (gates, scoring, offer page).<br>
      <strong>Paused</strong> sends every visitor to the safe page with no filtering — clicks are still logged so you can audit traffic. Use this to "switch off" a campaign without deleting it.<br>
      <strong>Archived</strong> makes the <code>/go/<%= campaign?.slug || 'slug' %></code> URL return 404. Use this when retiring a campaign permanently.
    </small>
  </div>

  <div class="form-row form-row-highlight">
    <label style="display:flex; align-items:center; gap:10px; margin-bottom:8px; cursor:pointer;">
      <input type="checkbox" name="indexable" <%= campaign?.indexable ? 'checked' : '' %>>
      <strong>Allow search engines to index this campaign</strong>
      <% if (campaign?.indexable) { %>
        <span class="badge badge-allow">Indexable</span>
      <% } else { %>
        <span class="badge badge-status-archived">Hidden from search</span>
      <% } %>
    </label>
    <small class="muted" style="display:block; margin-top:8px;">
      <strong>Default: off.</strong> Most campaigns are paid-traffic destinations and should not appear in Google/Bing — organic clicks aren't filtered by your gates and could trigger ad-platform quality reviews for cloaking discrepancies.
      <br>
      Turn this <strong>on</strong> for campaigns where organic SEO traffic is desired (evergreen landing pages, content marketing, brand pages). When on:
      <ul style="margin: 4px 0 0 20px; padding: 0;">
        <li>The URL is added to <code>/sitemap.xml</code></li>
        <li><code>/robots.txt</code> emits an <code>Allow:</code> rule for it</li>
        <li>The <code>X-Robots-Tag: noindex</code> header is dropped from responses</li>
      </ul>
      <strong style="color: var(--warning);">Caveat:</strong> indexable campaigns still run through your full filter chain. If gates (country, proxy, UTM) reject Googlebot, crawlers see only the safe page or a 404. Consider relaxing gates for indexable campaigns or setting <code>filter_config.mode</code> to <code>log_only</code>.
    </small>
  </div>

  <div class="form-row">
    <label>Source Profile</label>
    <select name="source_profile">
      <% ['mixed', 'email', 'paid_ads', 'organic', 'affiliate'].forEach(s => { %>
        <option value="<%= s %>" <%= campaign?.source_profile === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
    <small class="muted">Determines how filter scores are weighted. Pick the dominant traffic source for this campaign.</small>
  </div>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Default Pages</legend>
    <p class="muted" style="margin-top:0;">
      Used when no per-device override is set below. The Offer page is shown to allowed visitors;
      the Safe page is shown when a gate fires (UTM / country / proxy / score).
    </p>

    <div class="grid-2">
      <div class="form-row">
        <label>Offer page (default)</label>
        <select name="landing_page_id">
          <option value="">– None (renders stub) –</option>
          <% pages.filter(p => p.kind !== 'safe').forEach(p => { %>
            <option value="<%= p._id %>" <%= campaign?.landing_page_id?.toString() === p._id.toString() ? 'selected' : '' %>>
              <%= p.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-row">
        <label>Safe page (default)</label>
        <select name="safe_page_id">
          <option value="">– None –</option>
          <% pages.filter(p => p.kind === 'safe').forEach(p => { %>
            <option value="<%= p._id %>" <%= campaign?.safe_page_id?.toString() === p._id.toString() ? 'selected' : '' %>>
              <%= p.name %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Per-Device Pages (optional)</legend>
    <p class="muted" style="margin-top:0;">
      Override the default Offer / Safe page per device class. Useful for app campaigns that
      want to deep-link to App Store on iPhone, Play Store on Android, etc. Leave any cell as
      "use default" to fall back to the campaign-wide default above.
    </p>

    <%
      const dp = campaign?.device_pages || {};
      const deviceClasses = [
        { key: 'iphone',  label: 'iPhone' },
        { key: 'android', label: 'Android' },
        { key: 'windows', label: 'Windows' },
        { key: 'mac',     label: 'Mac' },
        { key: 'linux',   label: 'Linux' },
        { key: 'other',   label: 'Other (iPad, TV, unknown)' },
      ];
      const offerPages = pages.filter(p => p.kind !== 'safe');
      const safePages  = pages.filter(p => p.kind === 'safe');
    %>

    <table class="table table-dense" style="margin-top:8px;">
      <thead>
        <tr>
          <th>Device class</th>
          <th>Offer page</th>
          <th>Safe page</th>
        </tr>
      </thead>
      <tbody>
        <% deviceClasses.forEach(d => { %>
          <tr>
            <td><strong><%= d.label %></strong></td>
            <td>
              <select name="device_pages[<%= d.key %>][offer]" style="width:100%;">
                <option value="">— use default —</option>
                <% offerPages.forEach(p => { %>
                  <option value="<%= p._id %>" <%= dp[d.key]?.offer?.toString() === p._id.toString() ? 'selected' : '' %>>
                    <%= p.name %>
                  </option>
                <% }) %>
              </select>
            </td>
            <td>
              <select name="device_pages[<%= d.key %>][safe]" style="width:100%;">
                <option value="">— use default —</option>
                <% safePages.forEach(p => { %>
                  <option value="<%= p._id %>" <%= dp[d.key]?.safe?.toString() === p._id.toString() ? 'selected' : '' %>>
                    <%= p.name %>
                  </option>
                <% }) %>
              </select>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </fieldset>

  <div class="form-row">
    <label>Filter Threshold (0–100)</label>
    <input type="number" name="threshold" min="0" max="100" value="<%= campaign?.filter_config?.threshold ?? 70 %>">
    <small class="muted">Block when total bot score reaches this value. Higher = more permissive.</small>
  </div>

  <div class="form-row">
    <label>Mode</label>
    <select name="mode">
      <option value="log_only" <%= campaign?.filter_config?.mode === 'log_only' ? 'selected' : '' %>>log_only — log decisions but always render offer</option>
      <option value="enforce" <%= campaign?.filter_config?.mode === 'enforce' ? 'selected' : '' %>>enforce — actually block bad traffic</option>
    </select>
  </div>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">UTM Gate</legend>
    <p class="muted" style="margin-top:0;">
      When enabled, visits missing required UTM keys are routed to the safe page. Useful to keep
      direct visits, scrapers, and stripped social shares off the offer page.
    </p>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="utm_gate_enabled"
          <%= campaign?.filter_config?.utm_gate?.enabled ? 'checked' : '' %>>
        Enable UTM gate
      </label>
    </div>

    <div class="form-row">
      <label>Required UTM keys</label>
      <%
        const requiredKeys = campaign?.filter_config?.utm_gate?.required_keys || ['source','medium','campaign'];
      %>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <% ['source', 'medium', 'campaign', 'term', 'content'].forEach(k => { %>
          <label style="font-weight:normal;">
            <input type="checkbox" name="utm_required_keys" value="<%= k %>"
              <%= requiredKeys.includes(k) ? 'checked' : '' %>>
            utm_<%= k %>
          </label>
        <% }) %>
      </div>
      <small class="muted">A visit must have ALL the checked keys present (and non-empty) to reach the offer.</small>
    </div>
  </fieldset>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Click Identifier Gate</legend>
    <p class="muted" style="margin-top:0;">
      Every real ad click carries a click identifier that the ad network auto-appends
      (Google: gclid/wbraid/gbraid, Bing: msclkid). When enabled, visits with valid UTMs
      but no click ID are routed to the safe page — catching copy/paste, scrapers, and URL replay bots.
    </p>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="clickid_gate_enabled"
          <%= campaign?.filter_config?.clickid_gate?.enabled ? 'checked' : '' %>>
        Enable Click ID gate
      </label>
    </div>

    <div class="form-row">
      <label>Accepted click identifiers</label>
      <%
        const acceptedIds = campaign?.filter_config?.clickid_gate?.accepted_ids || ['gclid','wbraid','gbraid'];
        const idGroups = {
          'Google Ads': [['gclid','gclid (standard)'], ['wbraid','wbraid (iOS app→web)'], ['gbraid','gbraid (iOS web→app)']],
          'Other platforms': [['msclkid','msclkid (Bing)'], ['fbclid','fbclid (Facebook/IG)'], ['ttclid','ttclid (TikTok)'], ['li_fat_id','li_fat_id (LinkedIn)'], ['twclid','twclid (Twitter/X)'], ['rdt_cid','rdt_cid (Reddit)']],
        };
      %>
      <% Object.entries(idGroups).forEach(([groupName, ids]) => { %>
        <div style="margin-bottom:10px;">
          <div class="muted" style="font-size:12px; font-weight:600; margin-bottom:4px;"><%= groupName %></div>
          <div style="display:flex; gap:14px; flex-wrap:wrap;">
            <% ids.forEach(([id, label]) => { %>
              <label style="font-weight:normal;">
                <input type="checkbox" name="clickid_accepted_ids" value="<%= id %>"
                  <%= acceptedIds.includes(id) ? 'checked' : '' %>>
                <%= label %>
              </label>
            <% }) %>
          </div>
        </div>
      <% }) %>
      <small class="muted">A visit needs AT LEAST ONE of the checked identifiers to reach the offer. Match these to the platform you're running: Google IDs for Google Ads, fbclid for Facebook, twclid for Twitter/X, rdt_cid for Reddit, etc.</small>
    </div>

    <div class="form-row">
      <label>Format validation</label>
      <% const vf = campaign?.filter_config?.clickid_gate?.validate_format || 'off'; %>
      <select name="clickid_validate_format" style="max-width:280px;">
        <option value="off"    <%= vf === 'off'    ? 'selected' : '' %>>Off — presence only</option>
        <option value="loose"  <%= vf === 'loose'  ? 'selected' : '' %>>Loose — length + charset checks</option>
        <option value="strict" <%= vf === 'strict' ? 'selected' : '' %>>Strict — platform patterns + entropy</option>
      </select>
      <small class="muted">
        Checks the click ID looks real, catching lazy fakes like <code>gclid=test</code> or <code>gclid=12345</code>.
        <strong>Loose</strong> is safe for all traffic. <strong>Strict</strong> adds platform-specific pattern
        and entropy checks (slightly higher false-positive risk). Note: only the ad platform can confirm a click ID is
        genuinely theirs — this catches obvious fakes, not sophisticated ones.
      </small>
    </div>
  </fieldset>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Country Gate</legend>
    <p class="muted" style="margin-top:0;">
      Cross-checks ProxyCheck's country verdict against your list. Whitelist mode = only listed
      countries pass. Blacklist mode = listed countries blocked.
      Requires <code>PROXYCHECK_API_KEY</code> to be set; otherwise <code>on_unknown</code> decides.
    </p>

    <%
      const cg = campaign?.filter_config?.country_gate || {};
      const cgList = Array.isArray(cg.countries) ? cg.countries.join(', ') : '';
    %>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="country_gate_enabled" <%= cg.enabled ? 'checked' : '' %>>
        Enable country gate
      </label>
    </div>

    <div class="grid-2">
      <div class="form-row">
        <label>Mode</label>
        <select name="country_gate_mode">
          <option value="whitelist" <%= cg.mode !== 'blacklist' ? 'selected' : '' %>>
            whitelist — only listed countries pass
          </option>
          <option value="blacklist" <%= cg.mode === 'blacklist' ? 'selected' : '' %>>
            blacklist — listed countries blocked
          </option>
        </select>
      </div>
      <div class="form-row">
        <label>If country unknown</label>
        <select name="country_gate_on_unknown">
          <option value="allow" <%= cg.on_unknown !== 'block' ? 'selected' : '' %>>
            allow (permissive — pass through)
          </option>
          <option value="block" <%= cg.on_unknown === 'block' ? 'selected' : '' %>>
            block (strict — show safe page)
          </option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <label>Country list (ISO 3166-1 alpha-2 codes, comma-separated)</label>
      <textarea name="country_list" rows="3" placeholder="US, CA, GB, AU, DE, FR"><%= cgList %></textarea>
      <small class="muted">
        Two-letter codes only. Common: US (United States), GB (United Kingdom), CA (Canada),
        AU (Australia), DE (Germany), FR (France), IN (India). Case insensitive; invalid entries are dropped.
      </small>
    </div>
  </fieldset>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Proxy Gate</legend>
    <p class="muted" style="margin-top:0;">
      Hard route to safe page on proxy/VPN/Tor detection. Reads ProxyCheck verdict +
      ASN/term blacklist. Tighter than score-based filtering — when this fires the visit
      is blocked regardless of other layers.
    </p>

    <%
      const pg = campaign?.filter_config?.proxy_gate || {};
      // Defaults align with model defaults: VPN/Tor/public/compromised ON, hosting OFF
      const defaultBool = (v, def) => v === undefined ? def : !!v;
    %>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="proxy_gate_enabled" <%= pg.enabled ? 'checked' : '' %>>
        Enable proxy gate
      </label>
    </div>

    <div class="form-row">
      <label>Block on detection of:</label>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_vpn" <%= defaultBool(pg.block_vpn, true) ? 'checked' : '' %>>
          VPN
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_tor" <%= defaultBool(pg.block_tor, true) ? 'checked' : '' %>>
          Tor
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_public_proxy" <%= defaultBool(pg.block_public_proxy, true) ? 'checked' : '' %>>
          Public proxy
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_compromised" <%= defaultBool(pg.block_compromised, true) ? 'checked' : '' %>>
          Compromised
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="proxy_block_hosting" <%= defaultBool(pg.block_hosting, false) ? 'checked' : '' %>>
          Datacenter / hosting
        </label>
      </div>
      <small class="muted">
        "Datacenter" is off by default because corporate VPNs land in those ranges and you'll false-positive real users.
      </small>
    </div>

    <div class="form-row">
      <label>Max risk score (ProxyCheck's own 0–100 score)</label>
      <input type="number" name="proxy_max_risk_score" min="0" max="100" value="<%= pg.max_risk_score ?? 100 %>">
      <small class="muted">Block when ProxyCheck's risk score exceeds this. 100 = disabled.</small>
    </div>
  </fieldset>

  <fieldset>
    <legend style="font-weight:600; padding:0 6px;">Bot Guard (Level 2)</legend>
    <p class="muted" style="margin-top:0;">
      Serves a client-side interstitial that checks browser timezone vs the IP's
      timezone, dwell time, interaction, and (optionally) WebGL before the offer
      is shown. Choose which device classes are challenged — the rest skip
      Level 2 and go straight through.
    </p>

    <%
      const bg = campaign?.filter_config?.bot_guard || {};
      const bgBool = (v, def) => v === undefined ? def : !!v;
      const bgDevices = Array.isArray(bg.devices) ? bg.devices : ['iphone','android','windows','mac','linux','other'];
      const deviceList = [
        { key: 'iphone',  label: 'iPhone' },
        { key: 'android', label: 'Android' },
        { key: 'windows', label: 'Windows' },
        { key: 'mac',     label: 'Mac' },
        { key: 'linux',   label: 'Linux' },
        { key: 'other',   label: 'Other' },
      ];
    %>

    <div class="form-row">
      <label style="font-weight:normal;">
        <input type="checkbox" name="bot_guard_enabled" <%= bg.enabled ? 'checked' : '' %>>
        Enable Bot Guard for this campaign
      </label>
    </div>

    <div class="form-row">
      <label>Challenge these devices:</label>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <% deviceList.forEach(function(d) { %>
          <label style="font-weight:normal;">
            <input type="checkbox" name="bot_guard_devices" value="<%= d.key %>"
              <%= bgDevices.includes(d.key) ? 'checked' : '' %>>
            <%= d.label %>
          </label>
        <% }); %>
      </div>
      <small class="muted">Device classes not ticked here bypass Level 2 entirely. If none are ticked while the guard is enabled, all devices are challenged.</small>
    </div>

    <div class="form-row">
      <label>Checks to run:</label>
      <div style="display:flex; gap:14px; flex-wrap:wrap;">
        <label style="font-weight:normal;">
          <input type="checkbox" name="bot_guard_timezone" <%= bgBool(bg.check_timezone, true) ? 'checked' : '' %>>
          Timezone (IP vs browser)
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="bot_guard_interaction" <%= bgBool(bg.check_interaction, true) ? 'checked' : '' %>>
          Interaction
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="bot_guard_dwell" <%= bgBool(bg.check_dwell, true) ? 'checked' : '' %>>
          Dwell time
        </label>
        <label style="font-weight:normal;">
          <input type="checkbox" name="bot_guard_webgl" <%= bgBool(bg.check_webgl, false) ? 'checked' : '' %>>
          WebGL / canvas
        </label>
      </div>
    </div>

    <div class="form-row">
      <label>Minimum dwell (ms)</label>
      <input type="number" name="bot_guard_min_dwell" min="1000" max="10000" value="<%= bg.min_dwell_ms ?? 2000 %>">
      <small class="muted">Time the visitor must stay on the interstitial. Clamped 1000–10000 ms.</small>
    </div>
  </fieldset>

  <div class="form-row">
    <label>S2S Postback URL <span class="muted">(optional)</span></label>
    <input type="text" name="postback_url" value="<%= campaign?.postback_url || '' %>" placeholder="https://your-tracker.example.com/postback?clickid={click_id}">
  </div>

  <div class="form-row">
    <label>Notes</label>
    <textarea name="notes" rows="3"><%= campaign?.notes || '' %></textarea>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= campaign ? 'Save changes' : 'Create campaign' %></button>
    <a href="/admin/campaigns" class="btn">Cancel</a>
  </div>
</form>

<% if (campaign && campaign._id) { %>
<%
  // Build the tracking URLs for this campaign
  const base = (typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl.replace(/\/$/, '') : '';
  const landingUrl = campaign.root_path
    ? `${base}/${campaign.root_path}`
    : `${base}/go/${campaign.slug}`;

  // The Final URL suffix — the full parameter string to paste into Google Ads.
  // Uses the compact tracking template with ValueTrack macros.
  const finalUrlSuffix = [
    'utm_source=google',
    'utm_medium=display_ads',
    `utm_campaign=${campaign.slug}`,
    'utm_content={placement}',
    'tm=tt',
    'ap=gads',
    'cid={campaignid}',
    'agid={adgroupid}',
    'aid={creative}',
    'kid={targetid}',
    'kw={keyword}',
    'nw={network}',
    'dv={device}',
    'mt={matchtype}',
    'pl={placement}',
  ].join('&');
%>
<section class="panel" style="margin-top:24px; border:1px solid var(--color-primary, #3b82f6);">
  <h3>📋 Google Ads Setup</h3>
  <p class="muted" style="margin-bottom:16px;">
    Copy these into your Google Ads campaign's <strong>Campaign URL options</strong>.
  </p>

  <div class="form-row">
    <label>Final URL <span class="muted">(the landing page URL for your ad)</span></label>
    <div style="display:flex; gap:8px; align-items:center;">
      <input type="text" id="final_url" readonly value="<%= landingUrl %>"
        style="flex:1; font-family:var(--font-mono); font-size:13px;" onclick="this.select()">
      <button type="button" class="btn btn-small" onclick="copyField('final_url', this)">Copy</button>
    </div>
  </div>

  <div class="form-row" style="margin-top:16px;">
    <label>Final URL suffix <span class="muted">(paste into "Final URL suffix" field)</span></label>
    <div style="display:flex; gap:8px; align-items:flex-start;">
      <textarea id="url_suffix" readonly rows="3"
        style="flex:1; font-family:var(--font-mono); font-size:12px; resize:vertical;"
        onclick="this.select()"><%= finalUrlSuffix %></textarea>
      <button type="button" class="btn btn-small" onclick="copyField('url_suffix', this)">Copy</button>
    </div>
    <small class="muted" style="margin-top:6px; display:block;">
      This captures campaign ID, ad group, creative, keyword, network, device, match type, and placement —
      all visible per-click in the ValueTrack panel. Google fills the <code>{...}</code> macros automatically.
    </small>
  </div>

  <details style="margin-top:12px;">
    <summary style="cursor:pointer; font-weight:600; font-size:13px;">Setup steps</summary>
    <div style="margin-top:10px; padding:12px 16px; background:var(--bg-code, #1a1a2e); border-radius:8px; font-size:13px; line-height:1.9;">
      <strong>1.</strong> In Google Ads, open your campaign → Settings → <strong>Campaign URL options</strong><br>
      <strong>2.</strong> Set your ad's <strong>Final URL</strong> to the landing URL above<br>
      <strong>3.</strong> Paste the suffix into <strong>Final URL suffix</strong><br>
      <strong>4.</strong> Click <strong>Test</strong> to verify, then Save<br>
      <strong>5.</strong> For app campaigns, the <code>{placement}</code> in utm_content becomes <code>mobileapp::1-{app_id}</code> automatically
    </div>
  </details>
</section>

<script>
function copyField(id, btn) {
  var el = document.getElementById(id);
  el.select();
  el.setSelectionRange(0, 99999);
  try {
    navigator.clipboard.writeText(el.value).then(function() {
      var orig = btn.textContent;
      btn.textContent = '✓ Copied';
      setTimeout(function(){ btn.textContent = orig; }, 1500);
    });
  } catch (e) {
    document.execCommand('copy');
    btn.textContent = '✓ Copied';
  }
}
</script>
<% } %>

