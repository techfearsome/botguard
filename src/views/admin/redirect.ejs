<%- include('../partials/header', { ws, page, title: 'Redirect Campaigns - BotGuard' }) %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
  <div>
    <h1 style="margin-bottom:4px;">Redirect Campaigns</h1>
    <p class="muted">Campaigns that redirect clean traffic (with per-device destinations) instead of showing an offer page. Same filtering as any campaign; filtered traffic still sees the safe page.</p>
  </div>
  <a href="/admin/campaigns/new?type=redirect" class="btn btn-primary">+ New redirect campaign</a>
</div>

<div style="display:flex; gap:6px; margin-bottom:16px; border-bottom:1px solid var(--border-subtle,#22303f);">
  <a href="/admin/redirect?tab=campaigns" class="btn btn-small" style="<%= tab==='campaigns' ? 'font-weight:700;' : 'opacity:.7;' %>">Campaigns</a>
  <a href="/admin/redirect?tab=logs" class="btn btn-small" style="<%= tab==='logs' ? 'font-weight:700;' : 'opacity:.7;' %>">Logs</a>
</div>

<% if (tab === 'campaigns') { %>
  <section class="panel">
    <% if (campaigns.length === 0) { %>
      <p class="muted">No redirect campaigns yet. Click <strong>New redirect campaign</strong> to create one — it uses the full campaign form with the type preset to Redirect.</p>
    <% } else { %>
      <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead><tr style="text-align:left; color:var(--text-secondary);">
          <th style="padding:8px 10px;">Name</th>
          <th style="padding:8px 10px;">Custom URL</th>
          <th style="padding:8px 10px;">Default destination</th>
          <th style="padding:8px 10px;">Device URLs</th>
          <th style="padding:8px 10px;">Delay</th>
          <th style="padding:8px 10px;">Redirects</th>
          <th style="padding:8px 10px;">Status</th>
          <th style="padding:8px 10px;"></th>
        </tr></thead>
        <tbody>
        <% campaigns.forEach(function(c){
             var ru = c.redirect_urls || {};
             var deviceSet = ['iphone','android','windows','mac','linux','other'].filter(function(d){ return ru[d] && ru[d].trim(); });
             var def = (ru.default || c.redirect_url || '');
        %>
          <tr style="border-top:1px solid var(--border-subtle,#1c2733);">
            <td style="padding:6px 10px;"><strong><%= c.name %></strong></td>
            <td style="padding:6px 10px; font-family:monospace;"><%= c.root_path ? ('/'+c.root_path) : ('/go/'+c.slug) %></td>
            <td style="padding:6px 10px; max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= def %>"><%= def || '—' %></td>
            <td style="padding:6px 10px;"><%= deviceSet.length ? deviceSet.join(', ') : '—' %></td>
            <td style="padding:6px 10px;"><%= c.redirect_delay_ms != null ? c.redirect_delay_ms+'ms' : '1500ms' %></td>
            <td style="padding:6px 10px;"><%= (countMap[String(c._id)] || 0).toLocaleString() %></td>
            <td style="padding:6px 10px;"><%= c.status %></td>
            <td style="padding:6px 10px;"><a href="/admin/campaigns/<%= c._id %>/edit" class="btn btn-small">Edit</a></td>
          </tr>
        <% }); %>
        </tbody>
      </table>
    <% } %>
  </section>
<% } else { %>
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
    <span class="muted" style="font-size:13px;"><%= totalCount.toLocaleString() %> total<% if (totalCount > 0) { %> — showing <%= showingFrom %>–<%= showingTo %><% } %> (passed + failed)</span>
    <a href="/admin/redirect/logs.csv?<%= new URLSearchParams(query).toString() %>" class="btn btn-small" title="Download up to 10,000 rows matching the current filters">Export CSV</a>
  </div>

  <form method="GET" class="filter-bar" style="margin-bottom:14px;">
    <input type="hidden" name="tab" value="logs">
    <select name="range" onchange="document.getElementById('rl-custom').style.display = this.value === 'custom' ? '' : 'none';">
      <% rangeOptions.forEach(opt => { %>
        <option value="<%= opt.value %>" <%= range && range.range === opt.value ? 'selected' : '' %>><%= opt.label %></option>
      <% }) %>
    </select>
    <span id="rl-custom" style="<%= range && range.range === 'custom' ? '' : 'display:none' %>; display:inline-flex; gap:6px; align-items:center;">
      <input type="date" name="date_from" value="<%= query.date_from || '' %>">
      <input type="date" name="date_to" value="<%= query.date_to || '' %>">
    </span>
    <select name="campaign">
      <option value="">All redirect campaigns</option>
      <% campaigns.forEach(c => { %>
        <option value="<%= c._id %>" <%= query.campaign === c._id.toString() ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
    <select name="decision">
      <option value="">All decisions</option>
      <% ['allow', 'block', 'would_block'].forEach(d => { %>
        <option value="<%= d %>" <%= query.decision === d ? 'selected' : '' %>><%= d %></option>
      <% }) %>
    </select>
    <input type="text" name="source" placeholder="utm_source" value="<%= query.source || '' %>">
    <input type="text" name="click_id" placeholder="gclid/wbraid/gbraid/fbclid/msclkid" value="<%= query.click_id || '' %>">
    <button type="submit" class="btn">Filter</button>
    <a href="/admin/redirect?tab=logs" class="btn">Reset</a>
  </form>

  <section class="panel">
    <% if (logs.length === 0) { %>
      <p class="muted">No redirect traffic in this range. Both passed redirects and filtered (safe-page) traffic appear here.</p>
    <% } else { %>
      <div style="overflow:auto; border:1px solid var(--border-subtle,#22303f); border-radius:8px;">
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <thead style="position:sticky; top:0; background:var(--color-background-secondary,#0f1720);">
            <tr style="text-align:left;">
              <th style="padding:8px 10px;">Time</th>
              <th style="padding:8px 10px;">Campaign</th>
              <th style="padding:8px 10px;">Result</th>
              <th style="padding:8px 10px;">Destination</th>
              <th style="padding:8px 10px;">IP</th>
              <th style="padding:8px 10px;">ASN / Org</th>
              <th style="padding:8px 10px;">Country</th>
              <th style="padding:8px 10px;">Device</th>
              <th style="padding:8px 10px;">Source</th>
              <th style="padding:8px 10px;">Click ID</th>
            </tr>
          </thead>
          <tbody>
          <% logs.forEach(function(c){
               var passed = c.page_rendered === 'redirect';
          %>
            <tr style="border-top:1px solid var(--border-subtle,#1c2733);">
              <td style="padding:6px 10px; white-space:nowrap;"><%= new Date(c.ts).toLocaleString() %></td>
              <td style="padding:6px 10px;"><%= c.campaign_id?.name || '—' %></td>
              <td style="padding:6px 10px;">
                <% if (passed) { %>
                  <span style="color:#34d399; font-weight:600;">redirected</span>
                <% } else { %>
                  <span style="color:#f87171; font-weight:600;">safe</span>
                  <% if (c.decision_reason) { %><br><span class="muted" style="font-size:11px;"><%= c.decision_reason %></span><% } %>
                <% } %>
              </td>
              <td style="padding:6px 10px; max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= c.redirect_destination || '' %>"><%= passed ? (c.redirect_destination || '—') : '—' %></td>
              <td style="padding:6px 10px; font-family:monospace;"><%= c.ip || '—' %></td>
              <td style="padding:6px 10px; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= c.asn ? ('AS'+c.asn+' ') : '' %><%= c.asn_org || '' %></td>
              <td style="padding:6px 10px;"><%= c.country || '—' %></td>
              <td style="padding:6px 10px;"><%= c.ua_parsed?.device_class || '—' %></td>
              <td style="padding:6px 10px;"><%= c.utm?.source || '—' %></td>
              <td style="padding:6px 10px; font-family:monospace; font-size:11px;">
                <% if (c.click_id) { %><a href="/admin/clicks/<%= c.click_id %>" title="Full click detail"><%= c.click_id.slice(0,12) %>…</a><% } else { %>—<% } %>
              </td>
            </tr>
          <% }); %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div style="display:flex; gap:8px; align-items:center; margin-top:14px; flex-wrap:wrap;">
          <%
            function pageUrl(n){
              var p = new URLSearchParams(query); p.set('tab','logs'); p.set('page_n', String(n)); p.set('per', String(perPage)); return '/admin/redirect?' + p.toString();
            }
          %>
          <% if (currentPage > 1) { %><a class="btn btn-small" href="<%= pageUrl(currentPage-1) %>">‹ Prev</a><% } %>
          <span class="muted" style="font-size:13px;">Page <%= currentPage %> of <%= totalPages %></span>
          <% if (currentPage < totalPages) { %><a class="btn btn-small" href="<%= pageUrl(currentPage+1) %>">Next ›</a><% } %>
          <span style="margin-left:auto;"></span>
          <form method="GET" style="display:inline-flex; gap:6px; align-items:center;">
            <% Object.entries(query).forEach(function(kv){ if (kv[0] !== 'per' && kv[0] !== 'page_n' && kv[1] !== '' && kv[1] != null) { %>
              <input type="hidden" name="<%= kv[0] %>" value="<%= kv[1] %>">
            <% } }); %>
            <input type="hidden" name="tab" value="logs">
            <label class="muted" style="font-size:12px;">Per page</label>
            <select name="per" onchange="this.form.submit()">
              <% perPageOptions.forEach(function(n){ %><option value="<%= n %>" <%= perPage === n ? 'selected' : '' %>><%= n %></option><% }); %>
            </select>
          </form>
        </div>
      <% } %>
    <% } %>
  </section>
<% } %>

<%- include('../partials/footer') %>
