<%- include('../partials/header', { ws, page, title: 'Click Detail - BotGuard' }) %>

<div class="page-header">
  <div>
    <h1>Click <code><%= click.click_id %></code></h1>
    <p class="muted">
      <%- localTime(click.ts) %> ·
      Campaign: <strong><%= click.campaign_id?.name || '–' %></strong> ·
      Profile: <%= click.scores?.profile_used || '–' %>
    </p>
  </div>
  <a href="/admin/clicks" class="btn">← Back to log</a>
</div>

<div class="grid-2">
  <section class="panel">
    <h3>Decision</h3>
    <p>
      <span class="badge badge-<%= click.decision %>" style="font-size:14px;padding:4px 12px;">
        <%= click.decision %>
      </span>
      <small class="muted"> mode: <%= click.mode_at_decision %></small>
    </p>
    <p><strong>Reason:</strong> <code><%= click.decision_reason %></code></p>
    <p><strong>Total score:</strong> <%= click.scores?.total ?? 0 %> / 100</p>
  </section>

  <section class="panel">
    <h3>Layer Scores</h3>
    <table class="table table-dense">
      <% ['network','headers','residential','behavior','pattern','referer'].forEach(k => { %>
        <tr>
          <td><%= k %></td>
          <td><%= click.scores?.[k] ?? 0 %></td>
          <td>
            <div class="bar"><div class="bar-fill" style="width:<%= Math.min(100, click.scores?.[k] ?? 0) %>%"></div></div>
          </td>
        </tr>
      <% }) %>
      <tr style="border-top:2px solid #ddd; font-weight:600;">
        <td>total</td>
        <td><%= click.scores?.total ?? 0 %></td>
        <td><div class="bar"><div class="bar-fill bar-total" style="width:<%= Math.min(100, click.scores?.total ?? 0) %>%"></div></div></td>
      </tr>
    </table>
  </section>
</div>

<section class="panel">
  <h3>Flags (<%= (click.scores?.flags || []).length %>)</h3>
  <div class="flag-cloud">
    <% (click.scores?.flags || []).forEach(f => { %>
      <span class="flag"><%= f %></span>
    <% }) %>
    <% if ((click.scores?.flags || []).length === 0) { %>
      <span class="muted">No flags raised.</span>
    <% } %>
  </div>
</section>

<div class="grid-2">
  <section class="panel">
    <h3>Network</h3>
    <table class="table table-dense">
      <tr><td>IP (hashed)</td><td><code><%= click.ip_hash || '–' %></code></td></tr>
      <tr><td>ASN</td><td><%= click.asn ? 'AS' + click.asn : '–' %> <small><%= click.asn_org || '' %></small></td></tr>
      <tr><td>Organisation</td><td><%= click.organisation || '–' %></td></tr>
      <tr>
        <td>Operator</td>
        <td>
          <% if (click.operator_name) { %>
            <strong><%= click.operator_name %></strong>
            <% if (click.operator_anonymity) { %>
              <span class="badge badge-<%= click.operator_anonymity === 'high' ? 'block' : (click.operator_anonymity === 'medium' ? 'warn' : 'allow') %>">
                anonymity: <%= click.operator_anonymity %>
              </span>
            <% } %>
            <% if (click.operator?.url) { %>
              <br><small><a href="<%= click.operator.url %>" target="_blank" rel="noopener"><%= click.operator.url %></a></small>
            <% } %>
            <% if (click.operator?.popularity) { %>
              <small class="muted"> · popularity: <%= click.operator.popularity %></small>
            <% } %>
            <% if (Array.isArray(click.operator?.services) && click.operator.services.length) { %>
              <br><small class="muted">services: <%= click.operator.services.join(', ') %></small>
            <% } %>
            <% if (Array.isArray(click.operator?.protocols) && click.operator.protocols.length) { %>
              <br><small class="muted">protocols: <%= click.operator.protocols.join(', ') %></small>
            <% } %>
          <% } else { %>–<% } %>
        </td>
      </tr>
      <tr><td>Country</td>
        <td>
          <% if (click.country) { %>
            <code><%= click.country %></code>
            <% if (click.country_name) { %><small> — <%= click.country_name %></small><% } %>
          <% } else { %>–<% } %>
        </td>
      </tr>
      <tr><td>Region / City</td><td><%= click.region || '–' %> / <%= click.city || '–' %></td></tr>
      <tr><td>IP type</td>
        <td>
          <% if (click.is_proxy) { %>
            <span class="badge badge-block"><%= click.proxy_type || 'PROXY' %></span>
          <% } %>
          <%= click.ip_type || '–' %>
          <% if (click.hosting) { %><span class="badge badge-warn">hosting</span><% } %>
          <% if (click.scraper) { %><span class="badge badge-block">scraper</span><% } %>
          <% if (typeof click.risk_score === 'number') { %>
            <small class="muted"> · risk <%= click.risk_score %>/100</small>
          <% } %>
        </td>
      </tr>
      <tr><td>UA</td><td><small><%= click.user_agent || '–' %></small></td></tr>
      <tr><td>Browser / OS</td><td><%= click.ua_parsed?.browser || '–' %> <%= click.ua_parsed?.browser_version || '' %> / <%= click.ua_parsed?.os || '–' %> <%= click.ua_parsed?.os_version || '' %></td></tr>
      <tr><td>Device</td>
        <td>
          <strong><%= click.ua_parsed?.device_label || click.ua_parsed?.device_type || '–' %></strong>
          <% if (click.ua_parsed?.device_vendor || click.ua_parsed?.device_model) { %>
            <small class="muted">
              (<%= click.ua_parsed?.device_vendor || '' %>
              <%= click.ua_parsed?.device_model || '' %>)
            </small>
          <% } %>
        </td>
      </tr>
      <tr><td>In-app</td><td><%= click.in_app_browser || '–' %></td></tr>
    </table>
  </section>

  <section class="panel">
    <h3>Attribution</h3>
    <table class="table table-dense">
      <% ['source','medium','campaign','term','content'].forEach(k => { %>
        <tr><td>utm_<%= k %></td><td><%= click.utm?.[k] || '–' %></td></tr>
      <% }) %>
      <%# Google Ads click identifiers. gclid is the deterministic one;
          wbraid/gbraid are iOS aggregate identifiers used when GCLID can't
          be sent due to App Tracking Transparency. Case-sensitive - displayed
          verbatim, never lowercased. %>
      <tr><td>gclid</td><td class="mono"><%= click.external_ids?.gclid || '–' %></td></tr>
      <tr><td>wbraid</td><td class="mono"><%= click.external_ids?.wbraid || '–' %></td></tr>
      <tr><td>gbraid</td><td class="mono"><%= click.external_ids?.gbraid || '–' %></td></tr>
      <tr><td>fbclid</td><td class="mono"><%= click.external_ids?.fbclid || '–' %></td></tr>
      <tr><td>msclkid</td><td class="mono"><%= click.external_ids?.msclkid || '–' %></td></tr>
      <tr><td>ttclid</td><td class="mono"><%= click.external_ids?.ttclid || '–' %></td></tr>
      <tr><td>li_fat_id</td><td class="mono"><%= click.external_ids?.li_fat_id || '–' %></td></tr>
      <tr><td>referer</td><td><small><%= click.referer || '–' %></small></td></tr>
    </table>
  </section>
</div>

<%# ── Layer 2: Residential Proxy Detection ──────────────────────────── %>
<% const ipgeo = click.ipgeo_security; %>
<% if (ipgeo) { %>
<section class="panel">
  <h3>
    Layer 2: Residential Proxy Detection
    <span class="badge" style="font-size:11px; margin-left:6px;
      background:<%= ipgeo.is_residential_proxy ? '#FCEBEB' : '#EAF3DE' %>;
      color:<%= ipgeo.is_residential_proxy ? '#A32D2D' : '#3B6D11' %>;">
      <%= ipgeo.is_residential_proxy ? 'RESIDENTIAL PROXY' : 'CLEAN' %>
    </span>
    <small class="muted" style="font-weight:normal; margin-left:8px;">
      via <%= ipgeo.provider || 'unknown' %>
      <% if (ipgeo.checked_at) { %> · checked <%- localTime(ipgeo.checked_at) %><% } %>
    </small>
  </h3>
  <div class="grid-2">
    <table class="table table-dense">
      <tr><td>Provider</td><td><strong><%= ipgeo.provider || '–' %></strong></td></tr>
      <tr><td>Residential proxy</td>
        <td><% if (ipgeo.is_residential_proxy) { %><span class="badge badge-block">YES</span><% if (ipgeo.proxy_provider_names?.length) { %> <small>— <%= ipgeo.proxy_provider_names.join(', ') %></small><% } %><% } else { %><span class="badge badge-allow">no</span><% } %></td>
      </tr>
      <tr><td>VPN</td>
        <td><% if (ipgeo.is_vpn) { %><span class="badge badge-warn">YES</span><% if (ipgeo.vpn_provider_names?.length) { %> <small>— <%= ipgeo.vpn_provider_names.join(', ') %></small><% } %><% } else { %><span class="badge badge-allow">no</span><% } %></td>
      </tr>
      <tr><td>Proxy</td><td><%= ipgeo.is_proxy ? '⚠ yes' : '–' %></td></tr>
      <tr><td>Tor</td><td><%= ipgeo.is_tor ? '⚠ yes' : '–' %></td></tr>
      <tr><td>Hosting/Cloud</td><td><%= ipgeo.is_hosting ? 'yes' : '–' %></td></tr>
    </table>
    <table class="table table-dense">
      <tr><td>Threat score</td>
        <td><strong><%= ipgeo.threat_score || 0 %></strong>/100
          <div class="bar" style="display:inline-block;vertical-align:middle;width:100px;margin-left:8px;">
            <div class="bar-fill" style="width:<%= Math.min(100,ipgeo.threat_score||0) %>%;background:<%= (ipgeo.threat_score||0)>=60?'#ef4444':(ipgeo.threat_score||0)>=30?'#f97316':'#22c55e' %>;"></div>
          </div>
        </td>
      </tr>
      <tr><td>Confidence</td><td><%= ipgeo.confidence || 0 %>%</td></tr>
      <% if (ipgeo.proxy_provider_names?.length) { %><tr><td>Proxy providers</td><td><%= ipgeo.proxy_provider_names.join(', ') %></td></tr><% } %>
      <% if (ipgeo.vpn_provider_names?.length) { %><tr><td>VPN providers</td><td><%= ipgeo.vpn_provider_names.join(', ') %></td></tr><% } %>
    </table>
  </div>
  <% const raw = ipgeo.raw; %>
  <% if (raw && ipgeo.provider === 'spur') { %>
    <h4 style="margin-top:16px;">Spur Client Intelligence</h4>
    <div class="grid-2">
      <table class="table table-dense">
        <tr><td>Infrastructure</td><td><strong><%= raw.infrastructure || '–' %></strong></td></tr>
        <% if (raw.organization) { %><tr><td>Organization</td><td><%= raw.organization %></td></tr><% } %>
        <% if (raw.as) { %><tr><td>ASN</td><td>AS<%= raw.as.number %> — <%= raw.as.organization %></td></tr><% } %>
        <% if (raw.risks?.length) { %><tr><td>Risks</td><td><div class="flag-cloud"><% raw.risks.forEach(r => { %><span class="flag" style="color:#ef4444;border-color:#ef4444;"><%= r %></span><% }) %></div></td></tr><% } %>
        <% if (raw.services?.length) { %><tr><td>Services</td><td><%= raw.services.join(', ') %></td></tr><% } %>
      </table>
      <table class="table table-dense">
        <% const cl = raw.client || {}; %>
        <% if (cl.count) { %><tr><td>Unique users</td><td><strong><%= cl.count %></strong> across <%= cl.countries || '?' %> countries</td></tr><% } %>
        <% if (cl.proxies?.length) { %><tr><td>Proxy providers</td><td><div class="flag-cloud"><% cl.proxies.forEach(p => { %><span class="flag" style="color:#f97316;border-color:#f97316;"><%= p.replace(/_PROXY$/,'').replace(/_/g,' ') %></span><% }) %></div></td></tr><% } %>
        <% if (cl.behaviors?.length) { %><tr><td>Behaviors</td><td><%= cl.behaviors.join(', ') %></td></tr><% } %>
        <% if (cl.types?.length) { %><tr><td>Client types</td><td><%= cl.types.join(', ') %></td></tr><% } %>
        <% if (cl.concentration) { %><tr><td>Concentration</td><td><%= cl.concentration.city %>, <%= cl.concentration.state %>, <%= cl.concentration.country %> <small class="muted">density: <%= cl.concentration.density %></small></td></tr><% } %>
      </table>
    </div>
    <% if (raw.tunnels?.length) { %>
      <h4 style="margin-top:12px;">Tunnels</h4>
      <table class="table table-dense">
        <tr><th>Type</th><th>Operator</th><th>Anonymous</th><th>Entries</th></tr>
        <% raw.tunnels.forEach(t => { %><tr><td><%= t.type %></td><td><strong><%= (t.operator||'').replace(/_/g,' ') %></strong></td><td><%= t.anonymous ? 'yes' : 'no' %></td><td><% if (t.entries?.length) { %><code><%= t.entries.join(', ') %></code><% } else { %>–<% } %></td></tr><% }) %>
      </table>
    <% } %>
  <% } %>
  <% if (raw && ipgeo.provider === 'ipinfo') { %>
    <% const rp = raw.residential_proxy || {}; %>
    <% if (rp.service) { %>
      <h4 style="margin-top:16px;">ipinfo.io Residential Proxy</h4>
      <table class="table table-dense">
        <tr><td>Service</td><td><strong><%= rp.service %></strong></td></tr>
        <% if (rp.last_seen) { %><tr><td>Last seen</td><td><%= rp.last_seen %></td></tr><% } %>
        <% if (rp.percent_days_seen != null) { %><tr><td>Persistence</td><td><%= rp.percent_days_seen %>% of last 7 days</td></tr><% } %>
      </table>
    <% } %>
  <% } %>
</section>
<% } %>

<%# Google Ads / Bing ValueTrack - dynamic parameters the ad platform
    substitutes at click time (keyword, matchtype, campaignid, etc.). Only
    show this panel if the click actually carried ValueTrack data; otherwise
    it would render a row of empty placeholders for every click which is
    noise.

    For data to show here, the advertiser must have set up their ad URL
    template to include the ValueTrack placeholders. The recommended Google
    template is:
      ?gclid={gclid}&campaignid={campaignid}&adgroupid={adgroupid}
       &keyword={keyword}&matchtype={matchtype}&network={network}
       &device={device}&placement={placement}&creative={creative}
    See https://support.google.com/google-ads/answer/6305348 for the full list. %>
<% const vtG = click.valuetrack?.google || {}; %>
<% const vtB = click.valuetrack?.bing || {}; %>
<% const hasVtG = Object.keys(vtG).length > 0; %>
<% const hasVtB = Object.keys(vtB).length > 0; %>

<% if (hasVtG || hasVtB) { %>
<section class="panel">
  <h3>ValueTrack <span class="muted" style="font-weight:normal; font-size:13px;">(ad platform's dynamic parameters)</span></h3>

  <% if (hasVtG) { %>
    <h4 style="margin-top:0;">Google Ads</h4>
    <table class="table table-dense">
      <% Object.entries(vtG).forEach(([k, v]) => { %>
        <tr><td><%= k %></td><td class="mono"><%= v %></td></tr>
      <% }) %>
    </table>
  <% } %>

  <% if (hasVtB) { %>
    <h4 style="margin-top:<%= hasVtG ? '16px' : '0' %>;">Bing Ads</h4>
    <table class="table table-dense">
      <% Object.entries(vtB).forEach(([k, v]) => { %>
        <tr><td><%= k %></td><td class="mono"><%= v %></td></tr>
      <% }) %>
    </table>
  <% } %>
</section>
<% } %>

<section class="panel">
  <h3>Fingerprint</h3>
  <% if (click.fingerprint && Object.keys(click.fingerprint).length > 0) { %>
    <table class="table table-dense">
      <% Object.entries(click.fingerprint).forEach(([k, v]) => { %>
        <tr><td><%= k %></td><td><code><%= typeof v === 'object' ? JSON.stringify(v) : v %></code></td></tr>
      <% }) %>
    </table>
  <% } else { %>
    <p class="muted">No fingerprint received. The JS challenge either didn't run (bot, prefetcher) or hasn't reported yet.</p>
  <% } %>
</section>

<section class="panel">
  <h3>Conversions (<%= conversions.length %>)</h3>

  <% if (click.page_rendered === 'offer') { %>
    <div style="background:<%= click.auto_conv_injected ? '#e8f4ea' : '#fef3c7' %>;color:<%= click.auto_conv_injected ? '#1f6b3a' : '#7a5b00' %>;padding:10px 12px;border-radius:4px;margin-bottom:12px;font-size:13px;">
      <strong>Auto-conversion injection:</strong>
      <% if (click.auto_conv_injected) { %>
        ✓ The auto-conversion script WAS injected into the offer page served to this visitor. If no conversion shows below, the visitor either didn't click a matching button, already had the dedup cookie set, or the click happened in an environment where the script couldn't run (script-blocking extensions, very old browsers, etc.).
      <% } else { %>
        ✗ The auto-conversion script was NOT injected. Either the offer page doesn't have auto-conversion tracking enabled, or this click was logged before the toggle was turned on.
        <% if (click.landing_page_id) { %>
          <br><a href="/admin/pages/<%= click.landing_page_id %>/edit">Edit the landing page →</a>
        <% } %>
      <% } %>
    </div>
  <% } %>

  <% if (conversions.length === 0) { %>
    <p class="muted">No conversions recorded for this click.</p>
  <% } else { %>
    <table class="table table-dense">
      <tr><th>Time</th><th>Event</th><th>Value</th><th>Source</th><th>Details</th></tr>
      <% conversions.forEach(c => { %>
        <tr>
          <td><%- localTime(c.ts) %></td>
          <td><%= c.event_name %></td>
          <td><%= c.value %> <%= c.currency %></td>
          <td>
            <%= c.source %>
            <% if (c.auto_detected) { %>
              <span class="badge badge-allow">auto</span>
            <% } %>
          </td>
          <td>
            <% if (c.auto_detected) { %>
              <% if (c.matched_term) { %>matched: <code><%= c.matched_term %></code><% } %>
              <% if (c.matched_text) { %><br><small class="muted">on: "<%= c.matched_text %>"</small><% } %>
              <% if (c.matched_element) { %><br><small class="muted">el: <code><%= c.matched_element %></code></small><% } %>
            <% } else { %>–<% } %>
          </td>
        </tr>
      <% }) %>
    </table>
  <% } %>
</section>

<style>
  .bar { background: var(--bg-input); border: 1px solid var(--border-default); height: 6px; border-radius: 3px; width: 200px; overflow: hidden; }
  .bar-fill { background: var(--info); height: 100%; transition: width .2s; }
  .bar-total { background: var(--warning); }
  .flag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }
  .flag { display: inline-block; padding: 2px 8px; background: var(--bg-input); border: 1px solid var(--border-default); color: var(--text-secondary); border-radius: 3px; font-family: var(--font-mono); font-size: 12px; }
</style>

<%- include('../partials/footer') %>
