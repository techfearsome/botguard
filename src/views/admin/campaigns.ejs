<%- include('../partials/header', { ws, page, title: 'Campaigns - BotGuard' }) %>

<div class="page-header">
  <div>
    <h1>Campaigns</h1>
    <p class="muted">Each campaign has a unique slug used in the public URL: <code>/go/&lt;slug&gt;</code></p>
  </div>
  <a href="/admin/campaigns/new" class="btn btn-primary">+ New Campaign</a>
</div>

<% if (campaigns.length === 0) { %>
  <div class="empty-state">
    <p>No campaigns yet.</p>
    <a href="/admin/campaigns/new" class="btn btn-primary">Create your first campaign</a>
  </div>
<% } else { %>
  <table class="table">
    <tr>
      <th>Name</th>
      <th>Slug / URL</th>
      <th>Profile</th>
      <th>Mode</th>
      <th>Gates</th>
      <th>Status</th>
      <th>Landing Page</th>
      <th></th>
    </tr>
    <% campaigns.forEach(c => { %>
      <tr>
        <td><strong><%= c.name %></strong></td>
        <td><code>/go/<%= c.slug %></code></td>
        <td><%= c.source_profile %></td>
        <td><span class="badge badge-mode-<%= c.filter_config?.mode %>"><%= c.filter_config?.mode || 'log_only' %></span></td>
        <td>
          <% const fc = c.filter_config || {}; %>
          <% if (fc.utm_gate?.enabled) { %>
            <span class="badge badge-allow" title="Required: <%= (fc.utm_gate.required_keys || []).join(', ') %>">UTM</span>
          <% } %>
          <% if (fc.country_gate?.enabled) { %>
            <span class="badge badge-allow" title="<%= fc.country_gate.mode %>: <%= (fc.country_gate.countries || []).join(', ') %>">
              <%= fc.country_gate.mode === 'blacklist' ? 'CTRY-' : 'CTRY+' %>
            </span>
          <% } %>
          <% if (fc.proxy_gate?.enabled) { %>
            <span class="badge badge-allow" title="Blocks: vpn=<%= fc.proxy_gate.block_vpn %> tor=<%= fc.proxy_gate.block_tor %> hosting=<%= fc.proxy_gate.block_hosting %>">PROXY</span>
          <% } %>
          <% if (!fc.utm_gate?.enabled && !fc.country_gate?.enabled && !fc.proxy_gate?.enabled) { %>
            <span class="muted">—</span>
          <% } %>
        </td>
        <td>
          <% if (c.status === 'active') { %>
            <span class="badge badge-allow" title="Active — full pipeline runs">Active</span>
          <% } else if (c.status === 'paused') { %>
            <span class="badge badge-block" title="All traffic goes to safe page">Paused</span>
          <% } else if (c.status === 'archived') { %>
            <span class="badge" style="background:#9ca3af; color:white;" title="URL returns 404">Archived</span>
          <% } else { %>
            <span class="badge"><%= c.status %></span>
          <% } %>
        </td>
        <td><%= c.landing_page_id?.name || '–' %></td>
        <td>
          <%# Quick toggle: switches active <-> paused without opening the form. %>
          <%# Posts to /campaigns/:id/toggle which flips between the two and redirects back. %>
          <% if (c.status === 'active') { %>
            <form method="POST" action="/admin/campaigns/<%= c._id %>/toggle" style="display:inline"
                  onsubmit="return confirm('Pause this campaign? All traffic will go to the safe page until you re-enable it.')">
              <button type="submit" class="btn btn-small" title="Send all traffic to safe page">Pause</button>
            </form>
          <% } else if (c.status === 'paused') { %>
            <form method="POST" action="/admin/campaigns/<%= c._id %>/toggle" style="display:inline">
              <button type="submit" class="btn btn-small" style="background:#10b981; color:white;" title="Resume normal pipeline">Resume</button>
            </form>
          <% } %>
          <a href="/admin/campaigns/<%= c._id %>/edit" class="btn btn-small">Edit</a>
          <a href="/admin/campaigns/<%= c._id %>/preview" class="btn btn-small" target="_blank" title="See exactly what HTML is served to visitors, including injected scripts">Preview</a>
          <form method="POST" action="/admin/campaigns/<%= c._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this campaign?')">
            <button type="submit" class="btn btn-small btn-danger">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
<% } %>

<%- include('../partials/footer') %>
