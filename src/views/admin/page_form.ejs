<%- include('../partials/header', { ws, page, title: (lp ? 'Edit' : 'New') + ' Page - BotGuard' }) %>

<div class="page-header">
  <h1><%= lp ? 'Edit Landing Page' : 'New Landing Page' %></h1>
</div>

<form method="POST" action="<%= lp ? '/admin/pages/' + lp._id : '/admin/pages' %>" class="form">
  <div class="form-row">
    <label>Name</label>
    <input type="text" name="name" value="<%= lp?.name || '' %>" required>
  </div>

  <div class="form-row">
    <label>Slug <span class="muted">(optional — auto-generated from name if empty)</span></label>
    <input type="text" name="slug" value="<%= lp?.slug || '' %>" pattern="[a-z0-9-]*" placeholder="leave blank to auto-generate">
  </div>

  <div class="form-row">
    <label>Kind</label>
    <select name="kind">
      <option value="offer" <%= lp?.kind === 'offer' ? 'selected' : '' %>>offer (real landing page)</option>
      <option value="safe" <%= lp?.kind === 'safe' ? 'selected' : '' %>>safe (shown to filtered traffic)</option>
    </select>
  </div>

  <div class="form-row">
    <label>HTML Template</label>
    <textarea name="html_template" rows="20" class="code" data-code-editor="html"><%= lp?.html_template || '' %></textarea>
    <small class="muted">Available placeholders: <code>{{click_id}}</code>, <code>{{utm_source}}</code>, <code>{{utm_medium}}</code>, <code>{{utm_campaign}}</code></small>
  </div>

  <% if ((lp?.kind || 'offer') !== 'safe') { %>
    <fieldset>
      <legend style="font-weight:600; padding:0 6px;">Auto-Conversion Tracking</legend>
      <p class="muted" style="margin-top:0;">
        Inject a small JS snippet into this page that automatically fires a conversion when
        the visitor clicks a button matching one of the terms below. Useful when the offer
        owner won't or can't add a postback. Dedupes per session for 30 days.
      </p>

      <%
        const ac = lp?.auto_conversion || {};
        const acTerms = Array.isArray(ac.terms) ? ac.terms.join('\n') : '';
      %>

      <div class="form-row">
        <label style="font-weight:normal;">
          <input type="checkbox" name="auto_conversion_enabled" <%= ac.enabled ? 'checked' : '' %>>
          Enable auto-conversion tracking on this page
        </label>
      </div>

      <div class="form-row">
        <label>Detection terms <span class="muted">(one per line, case-insensitive substring match)</span></label>
        <textarea name="auto_conversion_terms" rows="6" placeholder="Download&#10;Submit&#10;Place Order&#10;Subscribe&#10;Sign Up&#10;Call&#10;Buy&#10;Get Started&#10;Continue&#10;Install"><%= acTerms %></textarea>
        <small class="muted">
          Leave blank to use the default list:
          <em>Download, Submit, Place Order, Subscribe, Sign Up, Sign In, Call, Buy, Get Started, Continue, Install, Order Now, Add to Cart, Checkout, Get the App, Open App</em>.
          Matches against the visible text of buttons, links, and elements with role=button.
        </small>
      </div>

      <div class="form-row">
        <label>Event name <span class="muted">(stored on the conversion record)</span></label>
        <input type="text" name="auto_conversion_event_name" value="<%= ac.event_name || 'auto_click' %>" placeholder="auto_click" maxlength="50">
        <small class="muted">e.g. <code>install</code>, <code>signup</code>, <code>purchase</code> — use this to differentiate when the same offer pays per type.</small>
      </div>
    </fieldset>
  <% } %>

  <%# Bot Guard (Level 2) — only for offer pages %>
  <% if ((lp?.kind || 'offer') !== 'safe') { %>
    <fieldset style="border:1px solid var(--border-default); border-radius:var(--radius-md); padding:16px; margin-bottom:16px;">
      <legend style="font-weight:600; padding:0 6px;">🛡 Bot Guard (Level 2)</legend>
      <%
        const bg = lp?.bot_guard || {};
      %>
      <div class="form-row">
        <label style="display:flex; align-items:center; gap:8px; font-weight:normal;">
          <input type="checkbox" name="bot_guard_enabled" <%= bg.enabled ? 'checked' : '' %> style="width:auto;">
          Enable Bot Guard on this offer page
        </label>
        <small class="muted">
          Visitors who pass Level 1 checks hit a loading interstitial that runs client-side
          checks (timezone, interaction, dwell time) before this offer page is served.
          Failing traffic is redirected to the safe page and logged. Disabled by default.
        </small>
      </div>

      <div style="margin-top:12px; padding-left:8px; border-left:2px solid var(--border-default);">
        <div class="form-row">
          <label style="display:flex; align-items:center; gap:8px; font-weight:normal;">
            <input type="checkbox" name="bot_guard_timezone" <%= bg.check_timezone !== false ? 'checked' : '' %> style="width:auto;">
            Timezone check <span class="muted">— compare IP timezone (ProxyCheck) vs browser timezone</span>
          </label>
          <small class="muted">Catches bots using a proxy in one region but running from another. Strongest signal.</small>
        </div>
        <div class="form-row">
          <label style="display:flex; align-items:center; gap:8px; font-weight:normal;">
            <input type="checkbox" name="bot_guard_interaction" <%= bg.check_interaction !== false ? 'checked' : '' %> style="width:auto;">
            Interaction check <span class="muted">— require mouse/touch/scroll movement</span>
          </label>
        </div>
        <div class="form-row">
          <label style="display:flex; align-items:center; gap:8px; font-weight:normal;">
            <input type="checkbox" name="bot_guard_dwell" <%= bg.check_dwell !== false ? 'checked' : '' %> style="width:auto;">
            Dwell time check <span class="muted">— minimum time on page</span>
          </label>
        </div>
        <div class="form-row">
          <label>Minimum dwell (milliseconds)</label>
          <input type="number" name="bot_guard_min_dwell" value="<%= bg.min_dwell_ms || 2000 %>" min="1000" max="10000" step="500" style="max-width:150px;">
          <small class="muted">How long the loading screen shows before checks run. 2000ms recommended.</small>
        </div>
        <div class="form-row">
          <label style="display:flex; align-items:center; gap:8px; font-weight:normal;">
            <input type="checkbox" name="bot_guard_webgl" <%= bg.check_webgl === true ? 'checked' : '' %> style="width:auto;">
            WebGL fingerprint check <span class="muted">— detect software rendering (headless)</span>
          </label>
          <small class="muted">Optional. Catches headless browsers using SwiftShader/llvmpipe. May cause false positives on some devices.</small>
        </div>
      </div>
    </fieldset>
  <% } %>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= lp ? 'Save changes' : 'Create page' %></button>
    <% if (lp?._id) { %>
      <a href="/admin/pages/<%= lp._id %>/preview" target="_blank" rel="noopener" class="btn" title="View this page as a visitor would (no tracking, no conversions). Save first to see latest changes.">Preview</a>
    <% } %>
    <a href="/admin/pages" class="btn">Cancel</a>
  </div>
</form>

<!-- Code editor enhancement: upgrades the HTML Template textarea to a
     CodeJar+Prism editor with syntax highlighting. Plain textarea remains
     functional if scripts fail to load. -->
<script src="<%= assetUrl('/static/js/vendor/prism.js') %>" defer></script>
<script src="<%= assetUrl('/static/js/code-editor.js') %>" type="module"></script>

<%- include('../partials/footer') %>
