<%- include('../partials/header', { ws, page, title: 'Live Visitors - BotGuard' }) %>

<div class="page-header">
  <div>
    <h1>Live Visitors <span class="live-pulse" title="Live updates active">●</span></h1>
    <p class="muted">Active visitors on your /go landing pages, updating in real-time. Visitors disappear from the list 30 seconds after their last heartbeat.</p>
  </div>
  <div style="display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
    <span class="live-conn" id="connection-status">Connecting…</span>
    <small class="muted">Last update: <span id="last-update">–</span></small>
  </div>
</div>

<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-label">Active right now</div>
    <div class="stat-value" id="stat-active"><%= snapshot.active %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">On offer pages</div>
    <div class="stat-value" id="stat-offer" style="color: var(--success);"><%= snapshot.on_offer %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">On safe pages</div>
    <div class="stat-value" id="stat-safe" style="color: var(--warning);"><%= snapshot.on_safe %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Conversions today</div>
    <div class="stat-value" id="stat-conv-today" style="color: var(--info);"><%= snapshot.conversions_today %></div>
    <div class="stat-sub">Resets at midnight</div>
  </div>
</div>

<section class="panel">
  <h3>Visitors</h3>
  <div id="empty-state" class="empty-state" style="<%= snapshot.visitors.length === 0 ? '' : 'display:none;' %>">
    <p>No active visitors right now. New visits will appear here automatically.</p>
  </div>
  <div id="visitor-list" style="display:flex; flex-direction:column; gap:8px;">
    <% snapshot.visitors.forEach(v => { %>
      <%- include('partials/_visitor_card', { v }) %>
    <% }) %>
  </div>
</section>

<script>

(function () {
  'use strict';

  // Live presence dashboard client.
  // Subscribes to /admin/live/stream (SSE), maintains a local Map of visitors,
  // updates the DOM in place, and ticks a "duration" counter once per second.

  const visitors = new Map();             // click_id -> visitor data
  const elements = new Map();             // click_id -> <div> in DOM

  const listEl = document.getElementById('visitor-list');
  const emptyEl = document.getElementById('empty-state');
  const statusEl = document.getElementById('connection-status');
  const lastUpdateEl = document.getElementById('last-update');
  const stats = {
    active: document.getElementById('stat-active'),
    offer: document.getElementById('stat-offer'),
    safe: document.getElementById('stat-safe'),
    convToday: document.getElementById('stat-conv-today'),
  };
  // Track current day so we can detect rollover client-side as a fallback
  let currentDay = '<%= snapshot.day %>';

  // Seed local state from the EJS-rendered cards (so we have data to update durations on).
  // The EJS template sets data attributes on each card.
  document.querySelectorAll('.visitor-card[data-cid]').forEach(function (el) {
    const cid = el.getAttribute('data-cid');
    const arrived = Number(el.getAttribute('data-arrived'));
    if (cid && !isNaN(arrived)) {
      visitors.set(cid, {
        click_id: cid,
        arrived_at: arrived,
        page_type: el.getAttribute('data-page'),
        converted: el.getAttribute('data-converted') === '1',
      });
      elements.set(cid, el);
    }
  });

  function fmtDuration(ms) {
    const s = Math.max(0, Math.floor(ms / 1000));
    if (s < 60) return s + 's';
    const m = Math.floor(s / 60);
    const r = s % 60;
    if (m < 60) return m + 'm ' + r + 's';
    const h = Math.floor(m / 60);
    return h + 'h ' + (m % 60) + 'm';
  }

  // Tick durations every second on every visible card
  setInterval(function () {
    const now = Date.now();
    elements.forEach(function (el, cid) {
      const v = visitors.get(cid);
      if (!v) return;
      const timeEl = el.querySelector('.v-time');
      if (timeEl) timeEl.textContent = fmtDuration(now - v.arrived_at);
    });
  }, 1000);

  function renderCard(v) {
    const utm = v.utm || {};
    const utmText = [utm.source, utm.medium, utm.campaign].filter(Boolean).join(' / ') || '–';
    const pageBadge = v.page_type === 'offer'
      ? '<span class="badge badge-page-offer">offer</span>'
      : v.page_type === 'safe'
      ? '<span class="badge badge-page-safe">safe</span>'
      : '<span class="badge">' + (v.page_type || 'unknown') + '</span>';
    const statusBadge = v.converted
      ? '<span class="badge badge-converted">converted</span>'
      : v.decision === 'block'
      ? '<span class="badge badge-block">blocked</span>'
      : '<span class="badge badge-allow">active</span>';

    const inApp = v.in_app_browser ? ' (' + escapeHtml(v.in_app_browser) + ')' : '';
    const proxy = v.is_proxy
      ? ' <span class="badge badge-block" style="font-size:10px;">' + escapeHtml((v.proxy_type || 'PROXY').toLowerCase()) + '</span>'
      : '';
    const convDetail = v.converted && v.conversion_term
      ? '<small class="muted"> · ' + escapeHtml(v.conversion_term) + (v.conversion_text ? ': "' + escapeHtml(truncate(v.conversion_text, 30)) + '"' : '') + '</small>'
      : '';

    return [
      '<div class="visitor-card is-new" data-cid="', escapeHtml(v.click_id),
        '" data-arrived="', v.arrived_at,
        '" data-page="', escapeHtml(v.page_type || ''),
        '" data-converted="', v.converted ? '1' : '0', '">',
      '<div class="v-cell">',
        '<div class="v-campaign">', escapeHtml(v.campaign_name || '–'), '</div>',
        '<div class="v-cid">', escapeHtml(v.click_id.slice(0, 12)), '…</div>',
      '</div>',
      '<div class="v-cell">',
        pageBadge, ' ', statusBadge, convDetail,
        '<div class="v-utm">', escapeHtml(utmText), '</div>',
      '</div>',
      '<div class="v-cell v-meta">',
        '<strong>', escapeHtml(v.ip || '–'), '</strong>', proxy,
        '<br>', escapeHtml(v.asn_org || '–'),
        v.country ? ' · ' + escapeHtml(v.country) : '',
      '</div>',
      '<div class="v-cell v-meta">',
        escapeHtml(v.device_label || '–'), inApp,
        v.ip_type ? '<br><small class="muted">' + escapeHtml(v.ip_type) + '</small>' : '',
      '</div>',
      '<div class="v-cell v-time">',
        fmtDuration(Date.now() - v.arrived_at),
      '</div>',
      '<div class="v-cell v-status">',
        '<a href="/admin/clicks/', escapeHtml(v.click_id), '" class="btn btn-small">Detail</a>',
      '</div>',
      '</div>'
    ].join('');
  }

  function upsertVisitor(v, isNew) {
    visitors.set(v.click_id, v);
    let el = elements.get(v.click_id);
    if (!el) {
      // Create new card and prepend to list
      const wrapper = document.createElement('div');
      wrapper.innerHTML = renderCard(v);
      el = wrapper.firstChild;
      elements.set(v.click_id, el);
      if (listEl.firstChild) listEl.insertBefore(el, listEl.firstChild);
      else listEl.appendChild(el);
      // Flash highlight then settle
      setTimeout(function () { el.classList.remove('is-new'); }, 2500);
    } else {
      // Update existing - replace the inner of v-cell elements but preserve scroll position
      const newWrapper = document.createElement('div');
      newWrapper.innerHTML = renderCard(v);
      const newEl = newWrapper.firstChild;
      el.replaceWith(newEl);
      elements.set(v.click_id, newEl);
      if (v.converted) newEl.classList.add('is-converted');
    }
    emptyEl.style.display = visitors.size === 0 ? '' : 'none';
  }

  function removeVisitor(clickId) {
    const v = visitors.get(clickId);
    visitors.delete(clickId);
    const el = elements.get(clickId);
    if (el) {
      el.classList.add('is-leaving');
      setTimeout(function () {
        el.remove();
        elements.delete(clickId);
        emptyEl.style.display = visitors.size === 0 ? '' : 'none';
      }, 600);
    }
  }

  function recomputeStats() {
    // Recomputes only the visitor-derived counters. The "Conversions today"
    // counter is fed by daily_stats SSE events, not by walking visitors -
    // because most visitors who converted earlier today are no longer in
    // the live tracker (they've left).
    let active = 0, offer = 0, safe = 0;
    visitors.forEach(function (v) {
      active += 1;
      if (v.page_type === 'offer') offer += 1;
      else if (v.page_type === 'safe') safe += 1;
    });
    stats.active.textContent = active;
    stats.offer.textContent = offer;
    stats.safe.textContent = safe;
  }

  function setLastUpdate() {
    lastUpdateEl.textContent = new Date().toLocaleTimeString();
  }

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function (c) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]);
    });
  }
  function truncate(s, n) {
    s = String(s || '');
    return s.length > n ? s.slice(0, n) + '…' : s;
  }

  // SSE connection
  let evtSource;
  function connect() {
    statusEl.textContent = 'Connecting…';
    statusEl.classList.remove('is-disconnected');

    evtSource = new EventSource('/admin/live/stream');

    evtSource.addEventListener('open', function () {
      statusEl.textContent = 'Connected · live';
      statusEl.classList.remove('is-disconnected');
    });

    evtSource.addEventListener('snapshot', function (e) {
      try {
        const snap = JSON.parse(e.data);
        // Reset state to match server's snapshot
        visitors.clear();
        Array.from(elements.values()).forEach(function (el) { el.remove(); });
        elements.clear();
        snap.visitors.forEach(function (v) { upsertVisitor(v); });
        stats.active.textContent = snap.active;
        stats.offer.textContent = snap.on_offer;
        stats.safe.textContent = snap.on_safe;
        stats.convToday.textContent = snap.conversions_today != null ? snap.conversions_today : 0;
        if (snap.day) currentDay = snap.day;
        emptyEl.style.display = snap.visitors.length === 0 ? '' : 'none';
        setLastUpdate();
      } catch (e) {}
    });

    evtSource.addEventListener('arrived', function (e) {
      try { upsertVisitor(JSON.parse(e.data), true); recomputeStats(); setLastUpdate(); } catch (e) {}
    });
    evtSource.addEventListener('updated', function (e) {
      try { upsertVisitor(JSON.parse(e.data)); recomputeStats(); setLastUpdate(); } catch (e) {}
    });
    evtSource.addEventListener('heartbeat', function (e) {
      try {
        const v = JSON.parse(e.data);
        const existing = visitors.get(v.click_id);
        if (existing) {
          existing.last_seen_at = v.last_seen_at;
          // Don't re-render - heartbeats are silent. The duration ticker handles display.
        }
        setLastUpdate();
      } catch (e) {}
    });
    evtSource.addEventListener('converted', function (e) {
      // Per-visitor converted event - update the card in place. The daily
      // counter is bumped via the separate daily_stats event below, so we
      // don't double-count.
      try { upsertVisitor(JSON.parse(e.data)); recomputeStats(); setLastUpdate(); } catch (e) {}
    });
    evtSource.addEventListener('daily_stats', function (e) {
      // Server-pushed counter update. Replace the displayed value rather
      // than incrementing locally - server is the source of truth, and
      // multiple admin tabs all see the same value this way.
      try {
        const stats = JSON.parse(e.data);
        if (stats.day && currentDay !== stats.day) {
          // Day rolled over since this dashboard was opened. Clear the per-card
          // "converted" state since those are stale (yesterday's conversions).
          currentDay = stats.day;
        }
        document.getElementById('stat-conv-today').textContent = stats.conversions_today;
        // Briefly highlight the card so the admin sees the bump
        const card = document.getElementById('stat-conv-today').closest('.stat-card');
        if (card) {
          card.style.transition = 'background-color .25s';
          card.style.backgroundColor = 'var(--info-bg)';
          setTimeout(function () { card.style.backgroundColor = ''; }, 600);
        }
        setLastUpdate();
      } catch (e) {}
    });
    evtSource.addEventListener('left', function (e) {
      try { removeVisitor(JSON.parse(e.data).click_id); recomputeStats(); setLastUpdate(); } catch (e) {}
    });

    evtSource.addEventListener('error', function () {
      statusEl.textContent = 'Reconnecting…';
      statusEl.classList.add('is-disconnected');
      // EventSource handles reconnect automatically; we just update status.
    });
  }
  connect();

  // Disconnect cleanly when leaving the page (not strictly needed, browsers
  // do this anyway, but it's polite to release the server-side handler)
  window.addEventListener('beforeunload', function () {
    if (evtSource) evtSource.close();
  });
})();
</script>

<%- include('../partials/footer') %>
