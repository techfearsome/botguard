<%- include('../partials/header', { ws, page, title: 'Click Log - BotGuard' }) %>

<div class="page-header">
  <div>
    <h1>Click Log</h1>
    <p class="muted">
      <% if (totalCount === 0) { %>
        No clicks in <strong><%= range.label %></strong>.
      <% } else { %>
        Showing <strong><%= showingFrom.toLocaleString() %>–<%= showingTo.toLocaleString() %></strong>
        of <strong><%= totalCount.toLocaleString() %></strong> clicks
        · <strong><%= range.label %></strong>.
        Use filters to narrow down.
      <% } %>
    </p>
  </div>
  <div>
    <a href="/admin/clicks.csv?<%= new URLSearchParams(query).toString() %>" class="btn" title="Download up to 10,000 rows matching the current filters">Export CSV</a>
  </div>
</div>

<form method="GET" class="filter-bar">
  <select name="range" onchange="document.getElementById('custom-dates').style.display = this.value === 'custom' ? '' : 'none';">
    <% rangeOptions.forEach(opt => { %>
      <option value="<%= opt.value %>" <%= range.range === opt.value ? 'selected' : '' %>><%= opt.label %></option>
    <% }) %>
  </select>

  <span id="custom-dates" style="<%= range.range === 'custom' ? '' : 'display:none' %>; display:inline-flex; gap:6px; align-items:center;">
    <input type="date" name="date_from" value="<%= query.date_from || '' %>" placeholder="From">
    <input type="date" name="date_to" value="<%= query.date_to || '' %>" placeholder="To">
  </span>

  <select name="campaign">
    <option value="">All campaigns</option>
    <% campaigns.forEach(c => { %>
      <option value="<%= c._id %>" <%= query.campaign === c._id.toString() ? 'selected' : '' %>><%= c.name %></option>
    <% }) %>
  </select>

  <select name="decision">
    <option value="">All decisions</option>
    <% ['allow', 'block', 'would_block'].forEach(d => { %>
      <option value="<%= d %>" <%= query.decision === d ? 'selected' : '' %>><%= d %></option>
    <% }) %>
  </select>

  <input type="text" name="source" placeholder="utm_source" value="<%= query.source || '' %>">

  <input type="text" name="click_id" placeholder="gclid/wbraid/gbraid/fbclid/msclkid" value="<%= query.click_id || '' %>" title="Search any ad-platform click ID. Case-sensitive exact match.">

  <button type="submit" class="btn">Filter</button>
  <a href="/admin/clicks" class="btn">Reset</a>
</form>

<% if (clicks.length === 0) { %>
  <div class="empty-state"><p>No clicks match these filters.</p></div>
<% } else { %>
  <div class="table-scroll"><table class="table table-dense">
    <tr>
      <th>Time</th>
      <th>Click ID</th>
      <th>Campaign</th>
      <th>UTM Source / Medium / Campaign</th>
      <th>IP</th>
      <th>Provider</th>
      <th>Type</th>
      <th>Country</th>
      <th>Device</th>
      <th>UA</th>
      <th>InApp</th>
      <th>Conv</th>
      <th>Decision</th>
    </tr>
    <% clicks.forEach(c => { %>
      <tr>
        <td><%- localTime(c.ts) %></td>
        <td><a href="/admin/clicks/<%= c.click_id %>"><code><%= c.click_id.slice(0, 12) %>…</code></a></td>
        <td class="cell-truncate-sm" title="<%= c.campaign_id?.name || '' %>"><%= c.campaign_id?.name || '–' %></td>
        <td class="cell-truncate-sm" title="<%= [c.utm?.source, c.utm?.medium, c.utm?.campaign].filter(Boolean).join(' / ') %>">
          <%= c.utm?.source || '–' %> / <%= c.utm?.medium || '–' %> / <%= c.utm?.campaign || '–' %>
        </td>
        <td><code><%= c.ip || '–' %></code></td>
        <td title="<%= c.organisation || '' %>">
          <% if (c.asn_org) { %>
            <%= c.asn_org %>
            <% if (c.asn) { %><br><small class="muted">AS<%= c.asn %></small><% } %>
          <% } else { %>–<% } %>
        </td>
        <td>
          <% if (c.is_proxy) { %>
            <span class="badge badge-block"><%= (c.proxy_type || 'PROXY').toLowerCase() %></span>
          <% } else if (c.ip_type) { %>
            <span class="badge badge-status-archived"><%= c.ip_type %></span>
          <% } else { %>–<% } %>
          <% if (c.hosting && !c.is_proxy) { %><br><small class="muted">hosting</small><% } %>
        </td>
        <td><%= c.country || '–' %></td>
        <td>
          <%= c.ua_parsed?.device_label || c.ua_parsed?.device_type || '–' %>
        </td>
        <td title="<%= c.user_agent %>">
          <%= c.ua_parsed?.browser || '–' %> / <%= c.ua_parsed?.os || '–' %>
          <% if (c.ua_parsed?.is_bot) { %><br><span class="badge badge-warn">bot-ish</span><% } %>
        </td>
        <td><%= c.in_app_browser || '–' %></td>
        <td>
          <% if (c.conversion_count > 0) { %>
            <span class="badge badge-allow"><%= c.conversion_count %></span>
            <% if (c.auto_conversion_count > 0) { %>
              <br><small class="muted" title="<%= c.auto_conversion_count %> auto-detected">auto</small>
            <% } %>
          <% } else { %>–<% } %>
        </td>
        <td><span class="badge badge-<%= c.decision %>"><%= c.decision %></span></td>
      </tr>
    <% }) %>
  </table></div>

  <%# Pagination control. Preserves all current filters via the form, so
      jumping pages doesn't lose the active query. The per-page selector
      auto-submits on change. The page number input is the only thing
      that's manually typed-and-submitted. %>
  <nav class="pagination" aria-label="Click log pagination">
    <% function paginationUrl(targetPage) {
         const params = new URLSearchParams(query);
         params.set('page_n', String(targetPage));
         params.set('per', String(perPage));
         return '/admin/clicks?' + params.toString();
       } %>

    <div class="pagination-controls">
      <% if (currentPage > 1) { %>
        <a href="<%= paginationUrl(1) %>" class="btn btn-small" title="First page">« First</a>
        <a href="<%= paginationUrl(currentPage - 1) %>" class="btn btn-small" rel="prev">‹ Prev</a>
      <% } else { %>
        <span class="btn btn-small disabled" aria-disabled="true">« First</span>
        <span class="btn btn-small disabled" aria-disabled="true">‹ Prev</span>
      <% } %>

      <span class="pagination-page-info">
        Page
        <form method="GET" action="/admin/clicks" style="display:inline">
          <%# Hidden inputs preserve every other filter. We deliberately
              forward `per` so a manually typed page number keeps the
              currently-selected per-page size. %>
          <% Object.entries(query).forEach(([k, v]) => { %>
            <% if (k !== 'page_n' && v !== '' && v != null) { %>
              <input type="hidden" name="<%= k %>" value="<%= v %>">
            <% } %>
          <% }) %>
          <input type="hidden" name="per" value="<%= perPage %>">
          <input type="number" name="page_n" value="<%= currentPage %>"
                 min="1" max="<%= totalPages %>"
                 style="width:70px; text-align:center;"
                 aria-label="Go to page number">
        </form>
        of <strong><%= totalPages.toLocaleString() %></strong>
      </span>

      <% if (currentPage < totalPages) { %>
        <a href="<%= paginationUrl(currentPage + 1) %>" class="btn btn-small" rel="next">Next ›</a>
        <a href="<%= paginationUrl(totalPages) %>" class="btn btn-small" title="Last page">Last »</a>
      <% } else { %>
        <span class="btn btn-small disabled" aria-disabled="true">Next ›</span>
        <span class="btn btn-small disabled" aria-disabled="true">Last »</span>
      <% } %>
    </div>

    <div class="pagination-per-page">
      <form method="GET" action="/admin/clicks" style="display:inline">
        <% Object.entries(query).forEach(([k, v]) => { %>
          <% if (k !== 'per' && k !== 'page_n' && v !== '' && v != null) { %>
            <input type="hidden" name="<%= k %>" value="<%= v %>">
          <% } %>
        <% }) %>
        <label class="muted" style="font-size:13px;">
          Per page:
          <select name="per" onchange="this.form.submit()">
            <% perPageOptions.forEach(n => { %>
              <option value="<%= n %>" <%= n === perPage ? 'selected' : '' %>><%= n %></option>
            <% }) %>
          </select>
        </label>
      </form>
    </div>
  </nav>
<% } %>

<%- include('../partials/footer') %>
