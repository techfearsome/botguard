<%- include('../partials/header', { ws, page, title: 'Click Log - BotGuard' }) %>

<div class="page-header">
  <h1>Click Log</h1>
  <p class="muted">Last 200 clicks · <strong><%= range.label %></strong>. Use filters to narrow down.</p>
</div>

<form method="GET" class="filter-bar">
  <select name="range" onchange="document.getElementById('custom-dates').style.display = this.value === 'custom' ? '' : 'none';">
    <% rangeOptions.forEach(opt => { %>
      <option value="<%= opt.value %>" <%= range.range === opt.value ? 'selected' : '' %>><%= opt.label %></option>
    <% }) %>
  </select>

  <span id="custom-dates" style="<%= range.range === 'custom' ? '' : 'display:none' %>; display:inline-flex; gap:6px; align-items:center;">
    <input type="date" name="date_from" value="<%= query.date_from || '' %>" placeholder="From">
    <input type="date" name="date_to" value="<%= query.date_to || '' %>" placeholder="To">
  </span>

  <select name="campaign">
    <option value="">All campaigns</option>
    <% campaigns.forEach(c => { %>
      <option value="<%= c._id %>" <%= query.campaign === c._id.toString() ? 'selected' : '' %>><%= c.name %></option>
    <% }) %>
  </select>

  <select name="decision">
    <option value="">All decisions</option>
    <% ['allow', 'block', 'would_block'].forEach(d => { %>
      <option value="<%= d %>" <%= query.decision === d ? 'selected' : '' %>><%= d %></option>
    <% }) %>
  </select>

  <input type="text" name="source" placeholder="utm_source" value="<%= query.source || '' %>">

  <button type="submit" class="btn">Filter</button>
  <a href="/admin/clicks" class="btn">Reset</a>
</form>

<% if (clicks.length === 0) { %>
  <div class="empty-state"><p>No clicks match these filters.</p></div>
<% } else { %>
  <table class="table table-dense">
    <tr>
      <th>Time</th>
      <th>Click ID</th>
      <th>Campaign</th>
      <th>UTM Source / Medium / Campaign</th>
      <th>IP</th>
      <th>Provider</th>
      <th>Type</th>
      <th>Country</th>
      <th>Device</th>
      <th>UA</th>
      <th>InApp</th>
      <th>Conv</th>
      <th>Decision</th>
    </tr>
    <% clicks.forEach(c => { %>
      <tr>
        <td><%= new Date(c.ts).toLocaleString() %></td>
        <td><a href="/admin/clicks/<%= c.click_id %>"><code><%= c.click_id.slice(0, 12) %>…</code></a></td>
        <td><%= c.campaign_id?.name || '–' %></td>
        <td>
          <%= c.utm?.source || '–' %> / <%= c.utm?.medium || '–' %> / <%= c.utm?.campaign || '–' %>
        </td>
        <td><code><%= c.ip || '–' %></code></td>
        <td title="<%= c.organisation || '' %>">
          <% if (c.asn_org) { %>
            <%= c.asn_org %>
            <% if (c.asn) { %><br><small class="muted">AS<%= c.asn %></small><% } %>
          <% } else { %>–<% } %>
        </td>
        <td>
          <% if (c.is_proxy) { %>
            <span class="badge badge-block"><%= (c.proxy_type || 'PROXY').toLowerCase() %></span>
          <% } else if (c.ip_type) { %>
            <span class="badge badge-status-archived"><%= c.ip_type %></span>
          <% } else { %>–<% } %>
          <% if (c.hosting && !c.is_proxy) { %><br><small class="muted">hosting</small><% } %>
        </td>
        <td><%= c.country || '–' %></td>
        <td>
          <%= c.ua_parsed?.device_label || c.ua_parsed?.device_type || '–' %>
        </td>
        <td title="<%= c.user_agent %>">
          <%= c.ua_parsed?.browser || '–' %> / <%= c.ua_parsed?.os || '–' %>
          <% if (c.ua_parsed?.is_bot) { %><br><span class="badge badge-warn">bot-ish</span><% } %>
        </td>
        <td><%= c.in_app_browser || '–' %></td>
        <td>
          <% if (c.conversion_count > 0) { %>
            <span class="badge badge-allow"><%= c.conversion_count %></span>
            <% if (c.auto_conversion_count > 0) { %>
              <br><small class="muted" title="<%= c.auto_conversion_count %> auto-detected">auto</small>
            <% } %>
          <% } else { %>–<% } %>
        </td>
        <td><span class="badge badge-<%= c.decision %>"><%= c.decision %></span></td>
      </tr>
    <% }) %>
  </table>
<% } %>

<%- include('../partials/footer') %>
